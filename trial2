-- FUNGSI UTILITY (dari kode asli, dipadatkan)
-- ============================================================
local function safeRequire(m) if not m then return end local ok,r=pcall(require,m) return ok and r or nil end
local function normalizeUsername(v) return tostring(v or ""):gsub("^%s*@?(.-)%s*$", "%1") end
local function callRemoteMethod(t,...) if not t then return end local a={...} if t.Fire then local o,e=pcall(t.Fire,t,unpack(a)) if o then return e end end if t.FireServer then local o,e=pcall(t.FireServer,t,unpack(a)) if o then return e end end if t.InvokeServer then local o,e=pcall(t.InvokeServer,t,unpack(a)) if o then return e end end if t.Invoke then local o,e=pcall(t.Invoke,t,unpack(a)) if o then return e end end return nil end

local function loadNetworkingModules()
    if SharedModules then Networking = safeRequire(SharedModules:FindFirstChild("Networking")) end
    if ClientModules then PlayerStateClient = safeRequire(ClientModules:FindFirstChild("PlayerStateClient")) end
    local cat = (function()
        local ps = LocalPlayer:FindFirstChild("PlayerScripts")
        local ctrl = ps and ps:FindFirstChild("Controllers")
        local mc = ctrl and ctrl:FindFirstChild("MailboxController")
        local m = mc and mc:FindFirstChild("MailboxItemCatalog")
        if m and m:IsA("ModuleScript") then return m end
        local r = ReplicatedStorage:FindFirstChild("MailboxItemCatalog", true)
        if r and r:IsA("ModuleScript") then return r end
        return nil
    end)()
    if cat then MailboxItemCatalog = safeRequire(cat) end
end
loadNetworkingModules()

