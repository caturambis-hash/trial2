-- FUNGSI INVENTORY & MAIL (dari kode asli, disederhanakan)
-- ============================================================
local function getLocalInventory()
    if not PlayerStateClient then return nil end
    local ok, rep = pcall(PlayerStateClient.GetLocalReplica, PlayerStateClient)
    if not ok or not rep or not rep.Data or not rep.Data.Inventory then return nil end
    return rep.Data.Inventory
end

local function collectReplicaInventoryEntries()
    local inv = getLocalInventory()
    if not inv then return {} end
    local entries = {}
    for cat, data in pairs(inv) do
        if cat == "Pets" then
            for key, val in pairs(data) do
                if val and val.Id and not val.Equipped then
                    table.insert(entries, { DisplayName = val.Name or key, Owned = 1, ItemKey = key, InventoryCategory = "Pets", Category = "Pets" })
                end
            end
        elseif cat == "Seeds" or cat == "Gear" then
            for key, qty in pairs(data) do
                if qty > 0 then
                    table.insert(entries, { DisplayName = key, Owned = qty, ItemKey = key, InventoryCategory = cat, Category = cat })
                end
            end
        end
    end
    return entries
end

local function lookupRecipient(username)
    username = normalizeUsername(username)
    if username == "" then return nil end
    if Networking and Networking.Mailbox and Networking.Mailbox.LookupPlayer then
        local ok, res = pcall(function() return callRemoteMethod(Networking.Mailbox.LookupPlayer, username) end)
        if ok and type(res) == "number" and res > 0 then return res end
    end
    local ok, id = pcall(Players.GetUserIdFromNameAsync, Players, username)
    if ok and type(id) == "number" and id > 0 then return id end
    return nil
end

local function sendBatch(userId, payload, note)
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.SendBatch then return false, "No SendBatch" end
    local ok, res, msg = pcall(function() return callRemoteMethod(Networking.Mailbox.SendBatch, userId, payload, tostring(note or "")) end)
    if not ok then return false, tostring(res) end
    if res == true then return true, tostring(msg or "Sent") end
    return false, tostring(msg or "Failed")
end

