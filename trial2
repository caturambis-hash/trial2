                btn.Text = e.DisplayName .. " ("..e.Owned..") ["..cat.."]"
                btn.Parent = itemList
                btn:SetAttribute("Category", cat)
                btn:SetAttribute("DisplayName", e.DisplayName)
                btn:SetAttribute("ItemKey", e.ItemKey)
                btn:SetAttribute("InventoryCategory", e.InventoryCategory)
                btn:SetAttribute("Quantity", e.Owned)
                btn:SetAttribute("Selected", false)
                btn.Visible = (cat == selectedCat)
                btn.Activated:Connect(function()
                    local sel = not btn:GetAttribute("Selected")
                    btn:SetAttribute("Selected", sel)
                    btn.BackgroundColor3 = sel and Color3.fromRGB(90,150,90) or Color3.fromRGB(60,60,60)
                end)
            end
