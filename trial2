        local recipient = userBox.Text
        if recipient == "" then setStatus("Masukkan username"); return end
        local qty = tonumber(qtyBox.Text) or 1
        local selected = {}
        for _, child in ipairs(itemList:GetChildren()) do
            if child:IsA("TextButton") and child:GetAttribute("Selected") then
                table.insert(selected, { name = child:GetAttribute("DisplayName"), key = child:GetAttribute("ItemKey"), category = child:GetAttribute("Category"), inventoryCategory = child:GetAttribute("InventoryCategory"), qty = child:GetAttribute("Quantity") or 1 })
            end
        end
        if #selected == 0 then setStatus("Tidak ada item terpilih"); return end
        local userId = lookupRecipient(recipient)
        if not userId then setStatus("Recipient tidak ditemukan"); return end
        local payload, sent = {}, 0
        for _, it in ipairs(selected) do
            if sent >= qty then break end
            local count = math.min(it.qty, qty - sent)
            table.insert(payload, { Category = it.inventoryCategory or it.category, ItemKey = it.key, Count = count })
            sent = sent + count
        end
        local ok, msg = sendBatch(userId, payload, settings.AutoMail.note)
        setStatus(ok and ("Terkirim "..sent.." item ke "..recipient) or ("Gagal: "..msg))
    end)
