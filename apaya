local function buildGiftPanel(panel)
    local giftState = {
        allItems = {},
        currentCategory = "Seeds",
        searchQuery = "",
        autoGiftEnabled = false,
        itemButtons = {},
    }

    -- Username & Qty
    local userBox = createInput(panel, "Username", "Ceszganteng", 0.5)
    local qtyBox = createInput(panel, "Qty", "20", 0.4)
    qtyBox.Position = UDim2.new(0.55,0,0,0)

    -- Tombol baris
    local btnRow = Instance.new("Frame")
    btnRow.BackgroundTransparency = 1
    btnRow.Size = UDim2.new(1,0,0,30)
    btnRow.Parent = panel

    local syncBtn = createButton(btnRow, "🔄 Sync", Color3.fromRGB(50,50,70), function()
        refreshInventory()
        notify("🔄 Synced", "Inventory updated", 1)
    end)
    syncBtn.Size = UDim2.new(0.23,0,0,24)

    local selectBtn = createButton(btnRow, "☑ All", Color3.fromRGB(60,60,70), function()
        for _, item in ipairs(giftState.allItems) do
            if item.Category == giftState.currentCategory then
                item.selected = true
            end
        end
        updateItemList()
    end)
    selectBtn.Size = UDim2.new(0.23,0,0,24)

    local clearBtn = createButton(btnRow, "☐ Clear", Color3.fromRGB(60,60,70), function()
        for _, item in ipairs(giftState.allItems) do
            if item.Category == giftState.currentCategory then
                item.selected = false
            end
        end
        updateItemList()
    end)
    clearBtn.Size = UDim2.new(0.23,0,0,24)

    local sendBtn = createButton(btnRow, "📤 Send", Color3.fromRGB(75,125,180), function()
        local recipient = userBox.Text
        if recipient == "" then notify("⚠ Error", "Username kosong", 2) return end
        local selected = {}
        for _, item in ipairs(giftState.allItems) do
            if item.selected then
                table.insert(selected, { Category = item.Category, ItemKey = item.ItemKey })
            end
        end
        if #selected == 0 then notify("⚠ Error", "Tidak ada item dipilih", 2) return end
        local userId = lookupRecipient(recipient)
        if not userId then notify("⚠ Error", "User tidak ditemukan", 2) return end
        local payload = buildPayload(selected)
        local ok, msg = sendMailBatch(userId, payload, "")
        if ok then
            notify("✅ Sent", #selected .. " items to " .. recipient, 2.5)
        else
            notify("❌ Failed", msg, 2.5)
        end
    end)
    sendBtn.Size = UDim2.new(0.23,0,0,24)

    -- Category tabs
    local catFrame = Instance.new("Frame")
    catFrame.BackgroundTransparency = 1
    catFrame.Size = UDim2.new(1,0,0,28)
    catFrame.Parent = panel

    local categories = {"Seeds", "Gear", "Crops", "Pets"}
    local catBtns = {}
    for i, cat in ipairs(categories) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0.23,0,0,22)
        btn.Position = UDim2.new((i-1)*0.25,0,0,0)
        btn.BackgroundColor3 = (i==1) and Color3.fromRGB(88,136,186) or Color3.fromRGB(50,50,56)
        btn.TextColor3 = Color3.fromRGB(240,240,240)
        btn.Text = cat
        btn.Font = Enum.Font.GothamSemibold
        btn.TextSize = 10
        btn.Parent = catFrame
        btn.MouseButton1Click:Connect(function()
            giftState.currentCategory = cat
            for _, b in ipairs(catBtns) do
                b.BackgroundColor3 = (b == btn) and Color3.fromRGB(88,136,186) or Color3.fromRGB(50,50,56)
            end
            updateItemList()
        end)
        table.insert(catBtns, btn)
    end

    -- Search bar
    local searchBox = Instance.new("TextBox")
    searchBox.Size = UDim2.new(1,0,0,24)
    searchBox.BackgroundColor3 = Color3.fromRGB(52,52,58)
    searchBox.TextColor3 = Color3.fromRGB(240,240,240)
    searchBox.PlaceholderText = "🔍 Search items..."
    searchBox.ClearTextOnFocus = false
    searchBox.Font = Enum.Font.Gotham
    searchBox.TextSize = 11
    searchBox.Parent = panel
    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        giftState.searchQuery = tostring(searchBox.Text):lower()
        updateItemList()
    end)

    -- Item list
    local itemFrame = Instance.new("ScrollingFrame")
    itemFrame.BackgroundColor3 = Color3.fromRGB(38,38,38)
    itemFrame.BorderSizePixel = 0
    itemFrame.Size = UDim2.new(1,0,0,180)
    itemFrame.ScrollBarThickness = 4
    itemFrame.Parent = panel

    local itemLayout = Instance.new("UIListLayout")
    itemLayout.Padding = UDim.new(0,2)
    itemLayout.SortOrder = Enum.SortOrder.LayoutOrder
    itemLayout.Parent = itemFrame

    -- Auto Gift toggle
    local autoToggle = createToggle(panel, "🔁 Auto Gift", false, function(s)
        giftState.autoGiftEnabled = s
        if s then
            notify("🔄 Auto Gift", "Started", 1.5)
            task.spawn(function()
                while giftState.autoGiftEnabled do
                    local recipient = userBox.Text
                    if recipient == "" then break end
                    local selected = {}
                    for _, item in ipairs(giftState.allItems) do
                        if item.selected then
                            table.insert(selected, { Category = item.Category, ItemKey = item.ItemKey })
                        end
                    end
                    if #selected > 0 then
                        local userId = lookupRecipient(recipient)
                        if userId then
                            local payload = buildPayload(selected)
                            sendMailBatch(userId, payload, "")
                        end
                    end
                    task.wait(3)
                end
            end)
        else
            notify("⏹ Auto Gift", "Stopped", 1.5)
        end
    end)

    -- ============================================================
    -- FUNGSI INTERNAL
    -- ============================================================
    local function refreshInventory()
        local entries = collectInventoryEntries()
        giftState.allItems = {}
        -- Jika dari replica tidak ada, pakai database sebagai fallback
        if #entries == 0 then
            for cat, list in pairs(ITEM_DB) do
                for _, name in ipairs(list) do
                    table.insert(giftState.allItems, {
                        DisplayName = name,
                        ItemKey = name,
                        Category = cat,
                        Quantity = 1,
                        selected = false,
                    })
                end
            end
        else
            for _, entry in ipairs(entries) do
                local cat = entry.Category
                if cat == "Seeds" or cat == "Gear" or cat == "Crops" or cat == "Pets" then
                    table.insert(giftState.allItems, {
                        DisplayName = entry.DisplayName,
                        ItemKey = entry.ItemKey,
                        Category = cat,
                        Quantity = entry.Quantity,
                        selected = false,
                    })
                end
            end
        end
        updateItemList()
    end

    local function updateItemList()
        for _, child in ipairs(itemFrame:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end

        local query = giftState.searchQuery
        local cat = giftState.currentCategory
        local count = 0
        for _, item in ipairs(giftState.allItems) do
            if item.Category == cat then
                local nameLower = tostring(item.DisplayName):lower()
                if query == "" or nameLower:find(query, 1, true) then
                    local btn = Instance.new("TextButton")
                    btn.Size = UDim2.new(1,0,0,20)
                    btn.BackgroundColor3 = item.selected and Color3.fromRGB(90,150,90) or Color3.fromRGB(60,60,60)
                    btn.TextColor3 = Color3.fromRGB(235,235,235)
                    btn.Font = Enum.Font.Gotham
                    btn.TextSize = 10
                    btn.Text = item.DisplayName .. " (" .. item.Quantity .. ")"
                    btn.Parent = itemFrame
                    btn.MouseButton1Click:Connect(function()
                        item.selected = not item.selected
                        btn.BackgroundColor3 = item.selected and Color3.fromRGB(90,150,90) or Color3.fromRGB(60,60,60)
                    end)
                    count = count + 1
                end
            end
        end
        itemFrame.CanvasSize = UDim2.new(0,0,0, itemLayout.AbsoluteContentSize.Y + 10)
        if count == 0 then
            local empty = Instance.new("TextLabel")
            empty.BackgroundTransparency = 1
            empty.Font = Enum.Font.Gotham
            empty.Text = "No items found"
            empty.TextColor3 = Color3.fromRGB(180,180,180)
            empty.TextSize = 11
            empty.Size = UDim2.new(1,0,0,20)
            empty.Parent = itemFrame
        end
    end

    refreshInventory()

    -- REAL-TIME SYNC (setiap 0.01 detik, tanpa UI)
    task.spawn(function()
        while true do
            if not panel or not panel.Parent then break end
            refreshInventory()
            task.wait(0.01)
        end
    end)
end

