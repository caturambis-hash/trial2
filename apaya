-- ============================================================
-- BUILD MAIN UI
-- ============================================================
local function buildUI()
    local old = PlayerGui:FindFirstChild("HubGUI")
    if old then old:Destroy() end

    local screen = Instance.new("ScreenGui")
    screen.Name = "HubGUI"
    screen.IgnoreGuiInset = true
    screen.Parent = PlayerGui

    -- Toggle show/hide
    local toggleScr = Instance.new("ScreenGui")
    toggleScr.Name = "HubToggle"
    toggleScr.IgnoreGuiInset = true
    toggleScr.Parent = PlayerGui
    local hideBtn = Instance.new("TextButton")
    hideBtn.Size = UDim2.new(0,34,0,34)
    hideBtn.Position = UDim2.new(1,-42,0,6)
    hideBtn.BackgroundColor3 = Color3.fromRGB(70,120,180)
    hideBtn.TextColor3 = Color3.fromRGB(245,245,245)
    hideBtn.Font = Enum.Font.GothamBold
    hideBtn.TextSize = 12
    hideBtn.Text = "☼"
    hideBtn.Parent = toggleScr
    Instance.new("UICorner", hideBtn).CornerRadius = UDim.new(1,0)
    local visible = true
    hideBtn.Activated:Connect(function()
        visible = not visible
        mainFrame.Visible = visible
        hideBtn.Text = visible and "☼" or "☾"
        hideBtn.BackgroundColor3 = visible and Color3.fromRGB(70,120,180) or Color3.fromRGB(92,92,102)
    end)

    -- Main frame
    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0,500,0,520)
    mainFrame.Position = UDim2.new(0.5,-250,0.08,0)
    mainFrame.BackgroundColor3 = Color3.fromRGB(20,18,28)
    mainFrame.BorderSizePixel = 0
    mainFrame.Active = true
    mainFrame.Draggable = true
    mainFrame.Parent = screen

    -- Title bar
    local titleBar = Instance.new("Frame")
    titleBar.BackgroundColor3 = Color3.fromRGB(40,30,48)
    titleBar.BorderSizePixel = 0
    titleBar.Size = UDim2.new(1,0,0,34)
    titleBar.Parent = mainFrame

    local titleLabel = Instance.new("TextLabel")
    titleLabel.BackgroundTransparency = 1
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.Text = "🌱 " .. PlayerName .. "'s Hub"
    titleLabel.TextColor3 = Color3.fromRGB(230,200,240)
    titleLabel.TextSize = 14
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Position = UDim2.new(0,10,0,0)
    titleLabel.Size = UDim2.new(1,-60,1,0)
    titleLabel.Parent = titleBar

    local minBtn = Instance.new("TextButton")
    minBtn.BackgroundColor3 = Color3.fromRGB(60,40,50)
    minBtn.BorderSizePixel = 0
    minBtn.Font = Enum.Font.Gotham
    minBtn.Text = "—"
    minBtn.TextColor3 = Color3.fromRGB(200,180,190)
    minBtn.TextSize = 16
    minBtn.Position = UDim2.new(1,-42,0,0)
    minBtn.Size = UDim2.new(0,28,1,0)
    minBtn.AutoButtonColor = false
    minBtn.Parent = titleBar

    -- Sidebar
    local sidebar = Instance.new("Frame")
    sidebar.BackgroundColor3 = Color3.fromRGB(34,34,38)
    sidebar.BorderSizePixel = 0
    sidebar.Size = UDim2.new(0,90,1,-34)
    sidebar.Position = UDim2.new(0,0,0,34)
    sidebar.Parent = mainFrame
    Instance.new("UICorner", sidebar).CornerRadius = UDim.new(0,6)

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.Padding = UDim.new(0,4)
    tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    tabLayout.VerticalAlignment = Enum.VerticalAlignment.Top
    tabLayout.Parent = sidebar

    -- Content
    local content = Instance.new("Frame")
    content.BackgroundTransparency = 1
    content.Size = UDim2.new(1,-100,1,-40)
    content.Position = UDim2.new(0,96,0,38)
    content.Parent = mainFrame

    local panels = {}
    local tabBtns = {}

    local function createTab(label, name, builder)
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1,-8,0,28)
        btn.BackgroundColor3 = Color3.fromRGB(50,50,56)
        btn.TextColor3 = Color3.fromRGB(240,240,240)
        btn.Text = label
        btn.Font = Enum.Font.GothamSemibold
        btn.TextSize = 11
        btn.AutoButtonColor = true
        btn.Parent = sidebar
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)

        local panel = Instance.new("ScrollingFrame")
        panel.BackgroundColor3 = Color3.fromRGB(38,38,38)
        panel.BorderSizePixel = 0
        panel.Size = UDim2.new(1,0,1,0)
        panel.ScrollBarThickness = 4
        panel.Visible = false
        panel.Parent = content
        -- Buat layout di dalam panel
        local layout = Instance.new("UIListLayout")
        layout.Padding = UDim.new(0,6)
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Parent = panel

        panels[name] = panel
        tabBtns[name] = btn

        btn.Activated:Connect(function()
            for _, p in pairs(panels) do p.Visible = false end
            for _, b in pairs(tabBtns) do b.BackgroundColor3 = Color3.fromRGB(50,50,56) end
            panel.Visible = true
            btn.BackgroundColor3 = Color3.fromRGB(88,136,186)
            -- Update canvas size
            panel.CanvasSize = UDim2.new(0,0,0, layout.AbsoluteContentSize.Y + 20)
        end)

        -- Panggil builder untuk mengisi panel
        if builder then builder(panel) end
        return panel
    end

    -- Buat semua tab
    createTab("📨 Gift", "Gift", buildGiftPanel)
    createTab("🛒 Buy", "Buy", buildBuyPanel)
    createTab("💰 Sell", "Sell", buildSellPanel)
    createTab("🌱 Plant", "Plant", buildPlantPanel)
    createTab("📦 Collect", "Collect", buildCollectPanel)
    createTab("🔄 Rollback", "Rollback", buildRollbackPanel)

    -- Aktifkan tab pertama
    panels.Gift.Visible = true
    tabBtns.Gift.BackgroundColor3 = Color3.fromRGB(88,136,186)

    -- ============================================================
    -- DRAG & MINIMIZE
    -- ============================================================
    local dragging = false
    local dragStart, frameStart
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            frameStart = mainFrame.Position
        end
    end)
    titleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.Position then
            local delta = input.Position - dragStart
            local newX = frameStart.X.Offset + delta.X
            local newY = frameStart.Y.Offset + delta.Y
            local vp = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(800,600)
            local maxX = math.max(0, vp.X - mainFrame.AbsoluteSize.X)
            local maxY = math.max(0, vp.Y - mainFrame.AbsoluteSize.Y)
            mainFrame.Position = UDim2.new(0, math.clamp(newX,0,maxX), 0, math.clamp(newY,0,maxY))
        end
    end)

    local minimized = false
    local origSize = mainFrame.Size
    minBtn.Activated:Connect(function()
        minimized = not minimized
        if minimized then
            TweenService:Create(mainFrame, TweenInfo.new(0.15), {
                Size = UDim2.new(0, mainFrame.Size.X.Offset, 0, 34)
            }):Play()
            content.Visible = false
            sidebar.Visible = false
            minBtn.Text = "□"
        else
            content.Visible = true
            sidebar.Visible = true
            TweenService:Create(mainFrame, TweenInfo.new(0.15, Enum.EasingStyle.Back), {
                Size = origSize
            }):Play()
            minBtn.Text = "—"
        end
    end)

    -- Animate in
    mainFrame.BackgroundTransparency = 1
    TweenService:Create(mainFrame, TweenInfo.new(0.2), { BackgroundTransparency = 0 }):Play()
    mainFrame.Position = UDim2.new(0.5, -250, 0.08, 50)
    TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
        Position = UDim2.new(0.5, -250, 0.08, 0)
    }):Play()

    -- Cleanup
    screen.AncestryChanged:Connect(function()
        if not screen:IsDescendantOf(game) then
            -- Hentikan semua loop (dengan state)
            state.giftAuto = false
            state.buyAuto = false
            state.sellAuto = false
            state.plantAuto = false
            state.collectAuto = false
            state.rollbackAuto = false
        end
    end)

    return screen
end

