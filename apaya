end

-- 3. AUTO COLLECT (tanpa firetouchinterest, pakai jarak)
local collectConnection = nil
local function toggleAutoCollect(state)
    features.autoCollect = state
    if state then
        collectConnection = RunService.Heartbeat:Connect(function()
            local char = player.Character
            if not char or not char.PrimaryPart then return end
            local pp = char.PrimaryPart
            -- Cari part yang memiliki TouchInterest (bisa di-collect)
            for _, item in ipairs(workspace:GetDescendants()) do
                if item:IsA("BasePart") and item:FindFirstChild("TouchInterest") then
                    local dist = (item.Position - pp.Position).Magnitude
                    if dist < 8 then
                        -- Simulasi sentuh dengan firetouchinterest (jika tersedia)
                        pcall(function()
                            -- Gunakan _G untuk menghindari undefined warning
                            if _G.firetouchinterest then
                                _G.firetouchinterest(pp, item, 0)
                                _G.firetouchinterest(pp, item, 1)
                            else
                                -- Alternatif: pindahkan part ke dekat player (simulasi)
                                item.CFrame = pp.CFrame + Vector3.new(0, 0, 2)
                            end
                        end)
                    end
                end
            end
        end)
        table.insert(connections, collectConnection)
        notify("📦 Auto Collect", "Mengumpulkan item", 1.5, Color3.fromRGB(60, 200, 100))
    else
        if collectConnection and collectConnection.Connected then
            collectConnection:Disconnect()
            collectConnection = nil
        end
        notify("📦 Auto Collect", "Dinonaktifkan", 1.2, Color3.fromRGB(200, 80, 80))
    end
end

-- 4. SPEED BOOST
local function toggleSpeed(state)
    features.speedBoost = state
    local char = player.Character
    if char and char:FindFirstChild("Humanoid") then
        local hum = char.Humanoid
        if state then
            hum.WalkSpeed = 50
            hum.JumpPower = 80
            notify("⚡ Speed Boost", "Kecepatan: 50 | Lompat: 80", 1.5, Color3.fromRGB(100, 180, 255))
        else
            hum.WalkSpeed = 16
            hum.JumpPower = 50
            notify("⚡ Speed Boost", "Dinonaktifkan", 1.2, Color3.fromRGB(200, 80, 80))
        end
    end
end

-- 5. FLY
local flyConnection = nil
local flyBodyVelocity = nil
local function toggleFly(state)
    features.fly = state
    local char = player.Character
    if not char then return end
    if state then
        flyBodyVelocity = Instance.new("BodyVelocity")
        flyBodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        flyBodyVelocity.Parent = char.PrimaryPart
        flyConnection = RunService.Heartbeat:Connect(function()
            if not char or not char.PrimaryPart then return end
            local dir = Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                dir = dir + char.PrimaryPart.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                dir = dir - char.PrimaryPart.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                dir = dir - char.PrimaryPart.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                dir = dir + char.PrimaryPart.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                dir = dir + Vector3.new(0, 1, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
                dir = dir - Vector3.new(0, 1, 0)
            end
            if dir.Magnitude > 0 then
                dir = dir.Unit * 50
            end
            if flyBodyVelocity then
                flyBodyVelocity.Velocity = dir
            end
        end)
        table.insert(connections, flyConnection)
        notify("✈️ Fly Mode", "WASD | Space naik | Shift turun", 2, Color3.fromRGB(100, 180, 255))
    else
        if flyConnection and flyConnection.Connected then
            flyConnection:Disconnect()
            flyConnection = nil
        end
        if flyBodyVelocity then
            flyBodyVelocity:Destroy()
            flyBodyVelocity = nil
        end
        notify("✈️ Fly Mode", "Dinonaktifkan", 1.2, Color3.fromRGB(200, 80, 80))
    end
end

-- 6. NO CLIP
local function toggleNoClip(state)
    features.noClip = state
    local char = player.Character
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = not state
            end
        end
    end
    if state then
        local conn = player.CharacterAdded:Connect(function(newChar)
            wait(0.1)
            for _, part in ipairs(newChar:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end)
        table.insert(connections, conn)
        notify("🚪 No Clip", "Tembus tembok aktif", 1.5, Color3.fromRGB(60, 200, 100))
    else
        notify("🚪 No Clip", "Dinonaktifkan", 1.2, Color3.fromRGB(200, 80, 80))
    end
end

-- 7. ESP
local espObjects = {}
local espConnection = nil
local function toggleESP(state)
    features.esp = state
    if state then
        for _, other in ipairs(Players:GetPlayers()) do
            if other ~= player then
                local char = other.Character
                if char then
                    local hl = Instance.new("Highlight")
                    hl.Name = "ESP"
                    hl.FillColor = Color3.fromRGB(255, 50, 50)
                    hl.FillTransparency = 0.4
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                    hl.Parent = char
                    table.insert(espObjects, hl)
                end
            end
        end
        espConnection = Players.PlayerAdded:Connect(function(newPlayer)
            if newPlayer ~= player then
                newPlayer.CharacterAdded:Connect(function(char)
                    wait(0.3)
                    local hl = Instance.new("Highlight")
                    hl.Name = "ESP"
                    hl.FillColor = Color3.fromRGB(255, 50, 50)
                    hl.FillTransparency = 0.4
                    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
                    hl.Parent = char
                    table.insert(espObjects, hl)
                end)
            end
        end)
        table.insert(connections, espConnection)
        notify("👁 ESP", "Player highlight aktif", 1.5, Color3.fromRGB(60, 200, 100))
    else
        for _, obj in ipairs(espObjects) do
            if obj and obj.Parent then
                obj:Destroy()
            end
        end
        espObjects = {}
        if espConnection and espConnection.Connected then
            espConnection:Disconnect()
            espConnection = nil
        end
        notify("👁 ESP", "Dinonaktifkan", 1.2, Color3.fromRGB(200, 80, 80))
    end
end

