    lbl.Font = Enum.Font.Gotham
    lbl.Text = label .. ": "
    lbl.TextColor3 = Color3.fromRGB(200,200,200)
    lbl.TextSize = 12
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Position = UDim2.new(0,0,0,0)
    lbl.Size = UDim2.new(0.3,0,1,0)
    lbl.Parent = frame

    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = Color3.fromRGB(50,50,60)
    btn.BorderSizePixel = 0
    btn.TextColor3 = Color3.fromRGB(240,240,240)
    btn.Text = default or options[1] or ""
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.Position = UDim2.new(0.35,0,0,0)
    btn.Size = UDim2.new(0.6,0,1,0)
    btn.Parent = frame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,4)

    local selected = default or options[1] or ""
    btn.MouseButton1Click:Connect(function()
        local current = btn.Text
        local idx = 1
        for i, opt in ipairs(options) do
            if opt == current then idx = i break end
        end
        local nextIdx = idx % #options + 1
        selected = options[nextIdx]
        btn.Text = selected
        if callback then callback(selected) end
    end)
    return { getValue = function() return selected end }
end

