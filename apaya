    toggleFrame.BackgroundColor3 = Color3.fromRGB(50, 45, 55)
    toggleFrame.BorderSizePixel = 0
    toggleFrame.Position = UDim2.new(1, -50 - 10, 0.5, -10)
    toggleFrame.Size = UDim2.new(0, 36, 0, 20)
    toggleFrame.Parent = container

    local toggleInner = Instance.new("Frame")
    toggleInner.BackgroundColor3 = Color3.fromRGB(80, 70, 90)
    toggleInner.BorderSizePixel = 0
    toggleInner.Position = UDim2.new(0, 2, 0, 2)
    toggleInner.Size = UDim2.new(0, 16, 0, 16)
    toggleInner.Parent = toggleFrame

    local statusLabel = Instance.new("TextLabel")
    statusLabel.BackgroundTransparency = 1
    statusLabel.Font = Enum.Font.Gotham
    statusLabel.Text = "OFF"
    statusLabel.TextColor3 = Color3.fromRGB(160, 140, 150)
    statusLabel.TextSize = 10
    statusLabel.TextXAlignment = Enum.TextXAlignment.Right
    statusLabel.Position = UDim2.new(1, -58 - 10, 0.5, -10)
    statusLabel.Size = UDim2.new(0, 35, 0, 20)
    statusLabel.Parent = container

    data.Container = container
    data.Frame = toggleFrame
    data.Inner = toggleInner
    data.Status = statusLabel

    local function update(state)
        data.Enabled = state
        TweenService:Create(toggleInner, TweenInfo.new(0.12, Enum.EasingStyle.Quad), {
            Position = state and UDim2.new(1, -18, 0, 2) or UDim2.new(0, 2, 0, 2),
            BackgroundColor3 = state and Color3.fromRGB(100, 200, 100) or Color3.fromRGB(80, 70, 90)
        }):Play()
        TweenService:Create(toggleFrame, TweenInfo.new(0.12), {
            BackgroundColor3 = state and Color3.fromRGB(60, 150, 60) or Color3.fromRGB(50, 45, 55)
        }):Play()
        TweenService:Create(statusLabel, TweenInfo.new(0.12), {
            Text = state and "ON" or "OFF",
            TextColor3 = state and Color3.fromRGB(120, 220, 120) or Color3.fromRGB(160, 140, 150)
        }):Play()
        if callback then callback(state) end
    end

    btn.MouseButton1Click:Connect(function() update(not data.Enabled) end)
    update(defaultState)
    return data
end

local function createButton(text, color, onClick)
    local btn = Instance.new("TextButton")
    btn.BackgroundColor3 = color or Color3.fromRGB(50, 40, 60)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.GothamBold
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(240, 220, 245)
    btn.TextSize = 13
    btn.AutoButtonColor = false
    btn.Size = UDim2.new(1, 0, 0, 32)
    btn.Parent = nil

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.08), {
            BackgroundColor3 = btn.BackgroundColor3:Lerp(Color3.new(0.15, 0.05, 0.2), 0.1)
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.08), {
            BackgroundColor3 = btn.BackgroundColor3:Lerp(Color3.new(0.2, 0.15, 0.25), 0.1)
        }):Play()
    end)

    if onClick then btn.MouseButton1Click:Connect(onClick) end
    return btn
end

