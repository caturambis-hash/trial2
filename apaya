-- Fungsi untuk format nama agar lebih cantik
local function formatItemName(raw)
    -- ubah "briar-rose" -> "Briar Rose"
    local name = raw:gsub("-", " "):gsub("^%l", string.upper)
    -- kapitalisasi setiap kata
    name = name:gsub("(%s)(%l)", function(space, letter) return space .. string.upper(letter) end)
    return name
end

