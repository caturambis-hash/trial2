        state.collectAuto = s
        if s then
            notify("📦 Auto Collect", "Started", 1.5)
            task.spawn(function()
                while state.collectAuto do
                    local fruit = fruitDropdown.getValue()
                    if state.collectAll then
                        -- Collect all fruits (loop through all types)
                        for _, f in ipairs(fruitOptions) do
