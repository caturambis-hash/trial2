local function buildUI()
    if playerGui:FindFirstChild("Hub") then
        playerGui.Hub:Destroy()
    end
    local container = createInstance("ScreenGui", {
        Name = "Hub",
        IgnoreGuiInset = true,
        Parent = playerGui
    })
    local mainFrame = createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(20, 18, 28),
        BorderSizePixel = 0,
        Size = UDim2.new(0, CONFIG.Width, 0, 300),
        Position = UDim2.new(1, 400, 0, 20),
        ClipsDescendants = false,
        Parent = container
    })
    createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
        Position = UDim2.new(0, -3, 0, 3),
        Size = UDim2.new(1, 6, 1, 6),
        Parent = mainFrame
    })
    -- Top bar
    local topBar = createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(40, 30, 48),
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, CONFIG.TitleHeight),
        Parent = mainFrame
    })
    createInstance("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = "✦ " .. playerName .. "'s Hub",
        TextColor3 = Color3.fromRGB(230, 200, 240),
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, CONFIG.Padding, 0, 0),
        Size = UDim2.new(1, -60, 1, 0),
        Parent = topBar
    })
    local minBtn = createInstance("TextButton", {
        BackgroundColor3 = Color3.fromRGB(60, 40, 50),
        BorderSizePixel = 0,
        Font = Enum.Font.Gotham,
        Text = "—",
        TextColor3 = Color3.fromRGB(200, 180, 190),
        TextSize = 18,
        Position = UDim2.new(1, -42, 0, 0),
        Size = UDim2.new(0, 28, 1, 0),
        AutoButtonColor = false,
        Parent = topBar
    })
    -- Content
    local content = createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(30, 25, 35),
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, -CONFIG.TitleHeight),
        Position = UDim2.new(0, 0, 0, CONFIG.TitleHeight),
        ClipsDescendants = false,
        Parent = mainFrame
    })
    local scroll = createInstance("ScrollingFrame", {
        BackgroundColor3 = Color3.fromRGB(30, 25, 35),
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 1, 0),
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = Color3.fromRGB(60, 40, 70),
        Parent = content
    })
    createInstance("UIPadding", {
        PaddingLeft = UDim.new(0, CONFIG.Padding),
        PaddingRight = UDim.new(0, CONFIG.Padding),
        PaddingTop = UDim.new(0, CONFIG.Padding),
        PaddingBottom = UDim.new(0, CONFIG.Padding),
        Parent = scroll
    })
    local layout = createInstance("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, CONFIG.Spacing),
        HorizontalAlignment = Enum.HorizontalAlignment.Left,
        Parent = scroll
    })

    -- Tambahkan toggle & button
    local farm = createToggle("🌾 Auto Farm", features.autoFarm, toggleAutoFarm)
    farm.Container.Parent = scroll; farm.Container.LayoutOrder = 1
    local click = createToggle("🖱 Auto Click", features.autoClick, toggleAutoClick)
    click.Container.Parent = scroll; click.Container.LayoutOrder = 2
    local collect = createToggle("📦 Auto Collect", features.autoCollect, toggleAutoCollect)
    collect.Container.Parent = scroll; collect.Container.LayoutOrder = 3
    local speed = createToggle("⚡ Speed Boost", features.speedBoost, toggleSpeed)
    speed.Container.Parent = scroll; speed.Container.LayoutOrder = 4
    local fly = createToggle("✈️ Fly Mode", features.fly, toggleFly)
    fly.Container.Parent = scroll; fly.Container.LayoutOrder = 5
    local noclip = createToggle("🚪 No Clip", features.noClip, toggleNoClip)
    noclip.Container.Parent = scroll; noclip.Container.LayoutOrder = 6
    local esp = createToggle("👁 ESP", features.esp, toggleESP)
    esp.Container.Parent = scroll; esp.Container.LayoutOrder = 7

    local rejoin = createButton("↻ Rejoin Server", Color3.fromRGB(50, 40, 60), function()
        notify("↻ Rejoining", "Menghubungkan ulang...", 2, Color3.fromRGB(60, 150, 200))
        delay(0.8, function() pcall(TeleportService.Teleport, TeleportService, game.PlaceId, player) end)
    end)
    rejoin.Parent = scroll; rejoin.LayoutOrder = 8

    local reset = createButton("🔄 Reset Character", Color3.fromRGB(60, 40, 50), function()
        if player.Character then
            player.Character:BreakJoints()
            notify("🔄 Reset", "Character di-reset", 1.5, Color3.fromRGB(200, 150, 60))
        end
    end)
    reset.Parent = scroll; reset.LayoutOrder = 9

    -- Update size
    local function updateSize()
        local h = layout.AbsoluteContentSize.Y
        local newH = CONFIG.Padding * 2 + h + CONFIG.Spacing + 10
        scroll.CanvasSize = UDim2.new(0, 0, 0, newH)
        local visible = math.min(newH + CONFIG.TitleHeight + 10, 450)
        mainFrame.Size = UDim2.new(0, CONFIG.Width, 0, visible)
    end
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateSize)
    updateSize()

    -- Drag
    local dragging = false
    local dragStart, frameStart = nil, nil
    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            frameStart = mainFrame.Position
        end
    end)
    topBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.Position then
            local delta = input.Position - dragStart
            local newX = frameStart.X.Offset + delta.X
            local newY = frameStart.Y.Offset + delta.Y
            local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(800, 600)
            local maxX = math.max(0, viewport.X - mainFrame.AbsoluteSize.X)
            local maxY = math.max(0, viewport.Y - mainFrame.AbsoluteSize.Y)
            mainFrame.Position = UDim2.new(0, math.clamp(newX, 0, maxX), 0, math.clamp(newY, 0, maxY))
        end
    end)

    -- Minimize
    local minimized = false
    local origSize = mainFrame.Size
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            TweenService:Create(mainFrame, TweenInfo.new(CONFIG.AnimSpeed), {
                Size = UDim2.new(0, CONFIG.Width, 0, CONFIG.TitleHeight)
            }):Play()
            content.Visible = false
            minBtn.Text = "□"
        else
            content.Visible = true
            TweenService:Create(mainFrame, TweenInfo.new(CONFIG.AnimSpeed, Enum.EasingStyle.Back), {
                Size = origSize
            }):Play()
            minBtn.Text = "—"
        end
    end)

    -- Animasi masuk (PERBAIKAN: pakai titik dua)
    mainFrame.BackgroundTransparency = 1
    TweenService:Create(mainFrame, TweenInfo.new(CONFIG.AnimSpeed), {
        BackgroundTransparency = 0
    }):Play()
    TweenService:Create(mainFrame, TweenInfo.new(CONFIG.AnimSpeed + 0.1, Enum.EasingStyle.Back), {
        Position = UDim2.new(1, -CONFIG.Width - 40, 0, 20)
    }):Play()

    -- Cleanup
    container.AncestryChanged:Connect(function()
        if not container:IsDescendantOf(game) then
            clearConnections()
        end
    end)

    return container
end

