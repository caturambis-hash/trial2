    PlayerGui:SetAttribute("HubInitialized", true)

    if isWhitelisted(PlayerName) then
        showNotification("✓ Whitelisted", "Welcome " .. PlayerName, 2.5, Color3.fromRGB(30,55,40), Color3.fromRGB(180,255,200))
