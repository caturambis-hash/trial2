-- RemoteEvent (dari ReplicatedStorage)
local RemoteEvent = nil
local function getRemoteEvent()
    if not RemoteEvent then
        -- Cari RemoteEvent di berbagai lokasi
        local possiblePaths = {
            ReplicatedStorage:FindFirstChild("RemoteEvent"),
            ReplicatedStorage:FindFirstChild("SharedModules"):FindFirstChild("Packet"):FindFirstChild("RemoteEvent"),
            ReplicatedStorage:FindFirstChild("Packet"):FindFirstChild("RemoteEvent"),
        }
        for _, path in ipairs(possiblePaths) do
            if path then
                RemoteEvent = path
                break
            end
        end
    end
    return RemoteEvent
end

local function fireServer(action, data)
    local remote = getRemoteEvent()
    if remote then
        pcall(function()
            remote:FireServer(action, data)
        end)
    end
end

