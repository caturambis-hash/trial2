-- KONFIGURASI CEPAT
-- =====================================================
local CONFIG = {
    Width = 340,
    TitleHeight = 50,
    Padding = 10,
    Spacing = 6,
    ButtonHeight = 38,
    ToggleHeight = 24,
    AnimSpeed = 0.12,  -- Lebih cepat
