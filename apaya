-- Auto Farm
local function toggleFarm(s)
    features.autoFarm = s
    if s then
        local c = RunService.Heartbeat:Connect(function()
            local char = LocalPlayer.Character
            if not char then return end
            local hum = char:FindFirstChild("Humanoid")
            if not hum then return end
            local target, dist = nil, math.huge
            for _, p in ipairs(workspace:GetDescendants()) do
                if p:IsA("BasePart") and (p.Name:lower():find("target") or p.Name:lower():find("farm")) then
                    local d = (p.Position - char.PrimaryPart.Position).Magnitude
                    if d < dist and d < 60 then dist = d; target = p end
                end
            end
            if target and hum then
                hum:MoveTo(target.Position)
                hum.WalkSpeed = math.max(hum.WalkSpeed, 25)
            end
        end)
        addConn(c)
    else
        for i=#connections,1,-1 do if connections[i] and connections[i].Connected then connections[i]:Disconnect() end end
        connections = {}
    end
end

