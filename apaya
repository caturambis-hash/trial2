-- ============================================================
-- FUNGSI UTILITY
-- ============================================================

local function normalizeText(text)
    text = tostring(text or ""):lower()
    text = text:gsub("%s+", " "):gsub("^%s*(.-)%s*$", "%1")
    return text
end

local function findItemInDatabase(input)
    local normalized = normalizeText(input)
    if normalized == "" then return nil, nil end
    
    -- Cek Seeds
    for _, item in ipairs(SEED_DATABASE) do
        local itemNorm = normalizeText(item)
        if normalized == itemNorm then
            return "Seeds", item
        end
        local aliases = SEED_ALIASES[item]
        if aliases then
            for _, alias in ipairs(aliases) do
                if normalized == normalizeText(alias) or normalized:find(normalizeText(alias), 1, true) then
                    return "Seeds", item
                end
            end
        end
    end
    
    -- Cek Pets
    for _, item in ipairs(PET_DATABASE) do
        local itemNorm = normalizeText(item)
        if normalized == itemNorm then
            return "Pets", item
        end
        local aliases = PET_ALIASES[item]
        if aliases then
            for _, alias in ipairs(aliases) do
                if normalized == normalizeText(alias) or normalized:find(normalizeText(alias), 1, true) then
                    return "Pets", item
                end
            end
        end
    end
    
    -- Cek Gear
    for _, item in ipairs(GEAR_DATABASE) do
        local itemNorm = normalizeText(item)
        if normalized == itemNorm then
            return "Gear", item
        end
        local aliases = GEAR_ALIASES[item]
        if aliases then
            for _, alias in ipairs(aliases) do
                if normalized == normalizeText(alias) or normalized:find(normalizeText(alias), 1, true) then
                    return "Gear", item
                end
            end
        end
    end
    
    return nil, nil
end

local function categorizeItem(input)
    local category, _ = findItemInDatabase(input)
    return category or "Other"
end

-- ============================================================
-- FUNGSI DETEKSI INVENTORY (Memperbaiki deteksi item)
-- ============================================================

local function getPlayerInventory()
    local inventory = {}
    
    -- Cek di berbagai lokasi inventory
    local searchLocations = {
        LocalPlayer:FindFirstChild("Backpack"),
        LocalPlayer:FindFirstChild("Inventory"),
        LocalPlayer:FindFirstChild("StarterPack"),
        LocalPlayer:FindFirstChild("Character"),
        ReplicatedStorage:FindFirstChild("Inventory"),
        ReplicatedStorage:FindFirstChild("Data"),
    }
    
    local function scanObject(obj, path)
        if not obj then return end
        
        -- Cek nama objek
        local objName = obj.Name or ""
        local objText = ""
        
        if obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
            objText = obj.Text or ""
        end
        
        -- Cek apakah ini item
        local combined = objName .. " " .. objText
        
        -- Cari di database
        local category, itemName = findItemInDatabase(combined)
        if category and itemName then
            local key = itemName
            if not inventory[key] then
                inventory[key] = { name = itemName, category = category, count = 0 }
            end
            inventory[key].count = inventory[key].count + 1
        end
        
        -- Scan children
        for _, child in ipairs(obj:GetChildren()) do
            scanObject(child, path .. "/" .. child.Name)
        end
    end
    
    for _, loc in ipairs(searchLocations) do
        if loc then
            scanObject(loc, loc.Name)
        end
    end
    
    return inventory
end

-- ============================================================
-- REMOTE EVENT
-- ============================================================

local RemoteEvent = nil
local function getRemoteEvent()
    if not RemoteEvent then
        local possiblePaths = {
            ReplicatedStorage:FindFirstChild("RemoteEvent"),
            ReplicatedStorage:FindFirstChild("SharedModules"):FindFirstChild("Packet"):FindFirstChild("RemoteEvent"),
            ReplicatedStorage:FindFirstChild("Packet"):FindFirstChild("RemoteEvent"),
        }
        for _, path in ipairs(possiblePaths) do
            if path then
                RemoteEvent = path
                break
            end
        end
    end
    return RemoteEvent
end

local function fireServer(action, data)
    local remote = getRemoteEvent()
    if remote then
        pcall(function()
            remote:FireServer(action, data)
        end)
    end
end

