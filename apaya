local BUY_SHOPS = {
    Seed = { prefix = "j", folderPath = "StockValues/SeedShop/Items" },
    Gear = { prefix = "n", folderPath = "StockValues/GearShop/Items" },
}

local function getReplicatedPathObject(path)
    local current = ReplicatedStorage
    for seg in string.gmatch(path or "", "([^/]+)") do
        if not current then return nil end
        current = current:FindFirstChild(seg)
    end
    return current
end

local function getStockValue(shopKey, itemName)
    local shop = BUY_SHOPS[shopKey]
    if not shop then return 0 end
    local folder = getReplicatedPathObject(shop.folderPath)
    if not folder then return 0 end
    local exact = folder:FindFirstChild(itemName)
    if exact and (exact:IsA("IntValue") or exact:IsA("NumberValue")) then return tonumber(exact.Value) or 0 end
    for _, child in ipairs(folder:GetChildren()) do
        if child:IsA("IntValue") or child:IsA("NumberValue") then
            if string.lower(child.Name) == string.lower(itemName) then
                return tonumber(child.Value) or 0
            end
        end
    end
    return 0
end

local function resolveStockItemName(shopKey, itemName)
    local shop = BUY_SHOPS[shopKey]
    if not shop then return itemName end
    local folder = getReplicatedPathObject(shop.folderPath)
    if not folder then return itemName end
    local query = string.lower(itemName)
    for _, child in ipairs(folder:GetChildren()) do
        if child:IsA("IntValue") or child:IsA("NumberValue") then
            if string.lower(child.Name) == query then
                return child.Name
            end
        end
    end
    return itemName
end

local function buyShopItem(shopKey, itemName)
    local shop = BUY_SHOPS[shopKey]
    if not shop then return false end
    local remote = getRemoteEvent()
    if not remote or type(remote.FireServer) ~= "function" then return false end
    local stockName = resolveStockItemName(shopKey, itemName)
    local stock = getStockValue(shopKey, stockName)
    if stock <= 0 then return false end
    if type(buffer) ~= "table" or type(buffer.fromstring) ~= "function" then return false end
    local payload = buffer.fromstring(shop.prefix .. "\x00" .. string.char(#stockName) .. stockName)
    local ok, _ = pcall(remote.FireServer, remote, payload)
    return ok
end

local function findBuyButtonForItem(itemName, categoryHint)
    -- Fungsi sederhana untuk mencari tombol beli di UI (fallback)
    for _, obj in ipairs(PlayerGui:GetDescendants()) do
        if (obj:IsA("GuiButton") or obj:IsA("ImageButton")) and obj.Visible and obj.Active then
            local text = (obj.Text or obj.Name or ""):lower()
            if text:find("buy", 1, true) or text:find("purchase", 1, true) then
                if text:find(string.lower(itemName), 1, true) then
                    return obj
                end
            end
        end
    end
    return nil
end

local function tryClickPurchaseTarget(itemName, categoryHint)
    local btn = findBuyButtonForItem(itemName, categoryHint)
    if btn and btn:IsA("GuiButton") then
        pcall(btn.Activated, btn)
        return true
    end
    return false
end

local autoBuySeedsEnabled = false
local autoBuyGearsEnabled = false
local autoBuySeedTargets = {}
local autoBuyGearTargets = {}
local autoLoopRunning = false

local function autoBuySeedOrGear()
    -- implementasi sederhana
    local candidates = {}
    if autoBuySeedsEnabled then
        for _, item in ipairs(SEED_DATABASE) do
            if autoBuySeedTargets[item] ~= false then
                table.insert(candidates, {Name = item, Category = "Seed"})
            end
        end
    end
    if autoBuyGearsEnabled then
        for _, item in ipairs(GEAR_DATABASE) do
            if autoBuyGearTargets[item] ~= false then
                table.insert(candidates, {Name = item, Category = "Gear"})
            end
        end
    end
    if #candidates == 0 then return false end
    for _, cand in ipairs(candidates) do
        local shopKey = cand.Category == "Gear" and "Gear" or "Seed"
        local stockName = resolveStockItemName(shopKey, cand.Name)
        local stock = getStockValue(shopKey, stockName)
        if stock > 0 then
            local ok = buyShopItem(shopKey, cand.Name)
            if ok then return true end
        end
        if tryClickPurchaseTarget(cand.Name, cand.Category) then
            return true
        end
    end
    return false
end

local function startAutomationLoop()
    if autoLoopRunning then return end
    autoLoopRunning = true
    task.spawn(function()
        while true do
            if not (autoBuySeedsEnabled or autoBuyGearsEnabled) then break end
            autoBuySeedOrGear()
            task.wait(1.2)
        end
        autoLoopRunning = false
    end)
end

