    title.TextColor3 = textColor
    title.TextSize = 15
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Position = UDim2.new(0, 10, 0, 6)
    title.Size = UDim2.new(1, -20, 0, 22)
    title.Parent = frame

    local sub = Instance.new("TextLabel")
    sub.BackgroundTransparency = 1
    sub.Font = Enum.Font.Gotham
    sub.Text = subText or ""
    sub.TextColor3 = Color3.fromRGB(180, 160, 170)
    sub.TextSize = 12
    sub.TextXAlignment = Enum.TextXAlignment.Left
    sub.Position = UDim2.new(0, 10, 0, 28)
    sub.Size = UDim2.new(1, -20, 0, 22)
    sub.Parent = frame

    local line = Instance.new("Frame")
    line.BackgroundColor3 = bgColor
    line.BorderSizePixel = 0
    line.Position = UDim2.new(0, 0, 0, 0)
    line.Size = UDim2.new(0, 4, 1, 0)
    line.Parent = frame

    TweenService:Create(frame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
        Position = UDim2.new(1, -390, 0, 20)
    }):Play()

    delay(duration, function()
        if frame and frame.Parent then
            TweenService:Create(frame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {
                Position = UDim2.new(1, 400, 0, 20)
            }):Play()
            delay(0.25, function()
                if container and container.Parent then
                    container:Destroy()
                end
            end)
        end
    end)

    return container
end

