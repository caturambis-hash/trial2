-- Panel Plant
local function buildPlantPanel(panel)
    local itemDropdown = createDropdown(panel, "Item", ITEM_DB.Seeds, ITEM_DB.Seeds[1])
    local locOptions = {"Center", "Edge", "Player Position", "Saved Position"}
    local locDropdown = createDropdown(panel, "Location", locOptions, "Center")

    local saveBtn = createButton(panel, "💾 Save Current Position", Color3.fromRGB(60,60,80), function()
        local char = LocalPlayer.Character
        if char and char.PrimaryPart then
            state.plantSavedPos = char.PrimaryPart.Position
            notify("💾 Saved", "Position saved", 1.5)
        else
            notify("⚠ Error", "Character not found", 1.5)
        end
    end)

    local autoToggle = createToggle(panel, "🌱 Auto Plant", state.plantAuto, function(s)
        state.plantAuto = s
        if s then
            notify("🌱 Auto Plant", "Started", 1.5)
            task.spawn(function()
                while state.plantAuto do
                    local item = itemDropdown.getValue()
                    local loc = locDropdown.getValue()
                    local char = LocalPlayer.Character
                    if char and char.PrimaryPart then
                        local targetPos = nil
                        if loc == "Center" then
                            targetPos = Vector3.new(0,0,0) -- ganti dengan posisi tengah plot
                        elseif loc == "Edge" then
                            targetPos = Vector3.new(10,0,10) -- ganti dengan posisi pinggir
                        elseif loc == "Player Position" then
                            targetPos = char.PrimaryPart.Position
                        elseif loc == "Saved Position" and state.plantSavedPos then
                            targetPos = state.plantSavedPos
                        end
                        if targetPos then
                            plantSeed(item, targetPos)
                            -- Simpan untuk rollback
                            if state.rollbackAuto then
                                savePlantedItem(item, targetPos)
                            end
                        end
                    end
                    task.wait(5)
                end
            end)
        else
            notify("⏹ Auto Plant", "Stopped", 1.5)
        end
    end)
end

