}

-- 1. AUTO FARM (lebih cepat dengan interval)
local farmConnection = nil
local function toggleAutoFarm(state)
    features.autoFarm = state
    if state then
        farmConnection = RunService.Heartbeat:Connect(function()
            local char = player.Character
            if not char then return end
            local hum = char:FindFirstChild("Humanoid")
            if not hum then return end
            -- Cari target terdekat (nama part sesuai game)
            local target, minDist = nil, math.huge
            local searchNames = {"Part", "Target", "Coin", "Gem", "Farm", "Node", "Crystal"}
            for _, name in ipairs(searchNames) do
                for _, part in ipairs(workspace:GetDescendants()) do
                    if part:IsA("BasePart") and string.find(part.Name:lower(), name:lower()) then
                        local dist = (part.Position - char.PrimaryPart.Position).Magnitude
                        if dist < minDist and dist < 60 then
                            minDist = dist
                            target = part
                        end
                    end
                end
            end
            if target and hum then
                hum:MoveTo(target.Position)
                hum.WalkSpeed = math.max(hum.WalkSpeed, 25)
            end
        end)
        table.insert(connections, farmConnection)
        notify("🌾 Auto Farm", "Aktif - mencari target", 1.5, Color3.fromRGB(60, 200, 100))
    else
        if farmConnection and farmConnection.Connected then
            farmConnection:Disconnect()
            farmConnection = nil
        end
        notify("🌾 Auto Farm", "Dinonaktifkan", 1.2, Color3.fromRGB(200, 80, 80))
    end
end

-- 2. AUTO CLICK
