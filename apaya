-- =====================================================
-- UTILITY
-- =====================================================
local connections = {}

local function createInstance(className, properties)
    local inst = Instance.new(className)
    if properties then
        for k, v in pairs(properties) do
            inst[k] = v
        end
    end
    return inst
end

local function clearConnections()
    for _, conn in ipairs(connections) do
        if conn and conn.Connected then
            pcall(conn.Disconnect, conn)
        end
    end
    connections = {}
end

-- Notifikasi cepat
local function notify(text, sub, dur, color)
    dur = dur or 2
    color = color or Color3.fromRGB(80, 60, 90)
    local container = createInstance("ScreenGui", {
        Name = "Notify",
        IgnoreGuiInset = true,
        Parent = playerGui
    })
    local frame = createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(20, 18, 25),
        BorderSizePixel = 0,
        Position = UDim2.new(1, 400, 0, 20),
        Size = UDim2.new(0, CONFIG.Width, 0, 55),
        ClipsDescendants = false,
        Parent = container
    })
    createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 0.4,
        BorderSizePixel = 0,
        Position = UDim2.new(0, -2, 0, 2),
        Size = UDim2.new(1, 4, 1, 4),
        Parent = frame
    })
    createInstance("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = text,
        TextColor3 = Color3.fromRGB(230, 200, 240),
        TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, CONFIG.Padding, 0, 6),
        Size = UDim2.new(1, -CONFIG.Padding * 2, 0, 22),
        Parent = frame
    })
    createInstance("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = sub or "",
        TextColor3 = Color3.fromRGB(180, 160, 170),
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, CONFIG.Padding, 0, 28),
        Size = UDim2.new(1, -CONFIG.Padding * 2, 0, 20),
        Parent = frame
    })
    createInstance("Frame", {
        BackgroundColor3 = color,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(0, 4, 1, 0),
        Parent = frame
    })
    TweenService:Create(frame, TweenInfo.new(CONFIG.AnimSpeed, Enum.EasingStyle.Quad), {
        Position = UDim2.new(1, -CONFIG.Width - 40, 0, 20)
    }):Play()
    delay(dur, function()
        if frame and frame.Parent then
            TweenService:Create(frame, TweenInfo.new(CONFIG.AnimSpeed, Enum.EasingStyle.Quad), {
                Position = UDim2.new(1, 400, 0, 20)
            }):Play()
            delay(0.25, function()
                if container and container.Parent then
                    container:Destroy()
                end
            end)
        end
    end)
    return container
end

-- =====================================================
-- FITUR-FITUR
-- =====================================================
local features = {
    autoFarm = false,
    autoClick = false,
    autoCollect = false,
