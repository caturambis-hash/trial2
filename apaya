-- ============================================================
-- AMBIL REMOTE EVENT
-- ============================================================
local function getRemote()
    local remote = ReplicatedStorage:FindFirstChild("RemoteEvent")
    if not remote then
        local packet = ReplicatedStorage:FindFirstChild("Packet")
        if packet then
            remote = packet:FindFirstChild("RemoteEvent")
        end
    end
    return remote
end

-- ============================================================
-- FUNGSI LOOKUP & SEND MAIL
-- ============================================================
local function lookupRecipient(username)
    if username == "" then return nil end
    local remote = getRemote()
    if remote then
        local ok, result = pcall(function()
            return remote:InvokeServer("LookupPlayer", username)
        end)
        if ok and type(result) == "number" and result > 0 then
            return result
        end
    end
    -- Fallback ke GetUserIdFromNameAsync
    local ok, id = pcall(Players.GetUserIdFromNameAsync, Players, username)
    if ok and type(id) == "number" and id > 0 then
        return id
    end
    return nil
end

local function sendMailBatch(userId, payload, note)
    local remote = getRemote()
    if not remote then
        return false, "Remote not found"
    end
    local ok, result = pcall(function()
        return remote:InvokeServer("SendBatch", userId, payload, note or "")
    end)
    if not ok then
        return false, tostring(result)
    end
    if result == true then
        return true, "Sent"
    end
    return false, tostring(result)
end

-- ============================================================
-- AMBIL INVENTORY DARI REPLICA
-- ============================================================
local function getInventoryReplica()
    local shared = ReplicatedStorage:FindFirstChild("SharedModules")
    if not shared then return nil end
    local client = shared:FindFirstChild("ClientModules")
    if not client then return nil end
    local psc = client:FindFirstChild("PlayerStateClient")
    if not psc then return nil end
    local ok, module = pcall(require, psc)
    if not ok or not module then return nil end
    local ok2, replica = pcall(module.GetLocalReplica, module)
    if not ok2 or not replica then return nil end
    return replica.Data and replica.Data.Inventory
end

local function collectInventoryEntries()
    local inventory = getInventoryReplica()
    if not inventory then
        -- Fallback: coba dari PlayerGui/Backpack sederhana
        local entries = {}
        local function scan(obj)
            if not obj then return end
            for _, child in ipairs(obj:GetDescendants()) do
                if child:IsA("TextLabel") or child:IsA("TextButton") then
                    local txt = child.Text or ""
                    if txt ~= "" then
                        local name = txt:match("^([^%d]+)") or txt
                        local qty = tonumber(txt:match("(%d+)$")) or 1
                        table.insert(entries, { DisplayName = name, ItemKey = name, Category = "Unknown", Quantity = qty })
                    end
                end
            end
        end
        scan(LocalPlayer:FindFirstChild("Backpack"))
        scan(LocalPlayer:FindFirstChild("Inventory"))
        return entries
    end
    
    local entries = {}
    for cat, data in pairs(inventory) do
        if cat == "Pets" then
            for key, val in pairs(data) do
                if val and val.Id and not val.Equipped then
                    table.insert(entries, { DisplayName = val.Name or key, ItemKey = key, Category = "Pets", Quantity = 1 })
                end
            end
        elseif cat == "Seeds" or cat == "Gear" or cat == "Crops" then
            for key, qty in pairs(data) do
                if qty > 0 then
                    table.insert(entries, { DisplayName = key, ItemKey = key, Category = cat, Quantity = qty })
                end
            end
        end
    end
    return entries
end

