local features = { autoFarm=false, autoClick=false, autoCollect=false, speedBoost=false, fly=false, noClip=false, esp=false }
local farmConnections = {}

local function toggleAutoFarm(state)
    features.autoFarm = state
    if state then
        local conn = RunService.Heartbeat:Connect(function()
            local c = LocalPlayer.Character
            if not c then return end
            local h = c:FindFirstChild("Humanoid")
            if not h then return end
            local target, dist = nil, math.huge
            for _, part in ipairs(workspace:GetDescendants()) do
                if part:IsA("BasePart") and (part.Name:lower():find("target") or part.Name:lower():find("farm")) then
                    local d = (part.Position - c.PrimaryPart.Position).Magnitude
                    if d < dist and d < 60 then dist = d; target = part end
                end
            end
            if target and h then h:MoveTo(target.Position); h.WalkSpeed = math.max(h.WalkSpeed, 25) end
        end)
        table.insert(farmConnections, conn)
    else
        for _, conn in ipairs(farmConnections) do if conn.Connected then conn:Disconnect() end end
        farmConnections = {}
    end
end

local function toggleAutoClick(state)
    features.autoClick = state
    if state then
        local conn = RunService.Heartbeat:Connect(function()
            pcall(function() VirtualUser:CaptureController() VirtualUser:ClickButton2(Vector2.new()) end)
        end)
        table.insert(farmConnections, conn)
    end
end

local function toggleAutoCollect(state)
    features.autoCollect = state
    if state then
        local conn = RunService.Heartbeat:Connect(function()
            local c = LocalPlayer.Character
            if not c or not c.PrimaryPart then return end
            for _, item in ipairs(workspace:GetDescendants()) do
                if item:IsA("BasePart") and item:FindFirstChild("TouchInterest") then
                    local dist = (item.Position - c.PrimaryPart.Position).Magnitude
                    if dist < 8 then
                        pcall(function()
                            if firetouchinterest then
                                firetouchinterest(c.PrimaryPart, item, 0)
                                firetouchinterest(c.PrimaryPart, item, 1)
                            end
                        end)
                    end
                end
            end
        end)
        table.insert(farmConnections, conn)
    end
end

local function toggleSpeed(state)
    features.speedBoost = state
    local c = LocalPlayer.Character
    if c and c:FindFirstChild("Humanoid") then
        local h = c.Humanoid
        h.WalkSpeed = state and 50 or 16
        h.JumpPower = state and 80 or 50
    end
end

local flyBV = nil
local function toggleFly(state)
    features.fly = state
    local c = LocalPlayer.Character
    if not c then return end
    if state then
        flyBV = Instance.new("BodyVelocity")
        flyBV.MaxForce = Vector3.new(1e5,1e5,1e5)
        flyBV.Velocity = Vector3.new(0,0,0)
        flyBV.Parent = c.PrimaryPart
        local conn = RunService.Heartbeat:Connect(function()
            if not c or not c.PrimaryPart then return end
            local dir = Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + c.PrimaryPart.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - c.PrimaryPart.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - c.PrimaryPart.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + c.PrimaryPart.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0,1,0) end
            if dir.Magnitude > 0 then dir = dir.Unit * 50 end
            if flyBV then flyBV.Velocity = dir end
        end)
        table.insert(farmConnections, conn)
    else
        if flyBV then flyBV:Destroy(); flyBV = nil end
    end
end

local function toggleNoClip(state)
    features.noClip = state
    local c = LocalPlayer.Character
    if c then
        for _, part in ipairs(c:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = not state end
        end
    end
end

local espObjs = {}
local function toggleESP(state)
    features.esp = state
    if state then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer then
                local ch = plr.Character
                if ch then
                    local h = Instance.new("Highlight")
                    h.FillColor = Color3.fromRGB(255,50,50)
                    h.FillTransparency = 0.4
                    h.OutlineColor = Color3.fromRGB(255,255,255)
                    h.Parent = ch
                    table.insert(espObjs, h)
                end
            end
        end
        local conn = Players.PlayerAdded:Connect(function(plr)
            plr.CharacterAdded:Connect(function(ch)
                wait(0.3)
                local h = Instance.new("Highlight")
                h.FillColor = Color3.fromRGB(255,50,50)
                h.FillTransparency = 0.4
                h.OutlineColor = Color3.fromRGB(255,255,255)
                h.Parent = ch
                table.insert(espObjs, h)
            end)
        end)
        table.insert(farmConnections, conn)
    else
        for _, obj in ipairs(espObjs) do if obj.Parent then obj:Destroy() end end
        espObjs = {}
    end
end

