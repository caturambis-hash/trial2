-- Panel Gift
local function buildGiftPanel(panel)
    -- Input username & qty
    local userBox = createInput(panel, "Username", state.giftUsername, 0.5)
    local qtyBox = createInput(panel, "Qty", tostring(state.giftQty), 0.4)
    qtyBox.Position = UDim2.new(0.55,0,0,0)

    -- Tombol Sync, Select All, Clear, Send
    local btnRow = Instance.new("Frame")
    btnRow.BackgroundTransparency = 1
    btnRow.Size = UDim2.new(1,0,0,30)
    btnRow.Parent = panel

    local syncBtn = createButton(btnRow, "🔄 Sync", Color3.fromRGB(50,50,70), function()
        notify("🔄 Syncing", "Fetching inventory...", 1.5)
        -- Di sini nanti diisi logic refresh item list
    end)
    syncBtn.Size = UDim2.new(0.23,0,0,24)

    local selectBtn = createButton(btnRow, "☑ All", Color3.fromRGB(60,60,70), function()
        for _, item in ipairs(state.giftItems) do item.selected = true end
        notify("☑ All selected", "All items selected", 1)
    end)
    selectBtn.Size = UDim2.new(0.23,0,0,24)

    local clearBtn = createButton(btnRow, "☐ Clear", Color3.fromRGB(60,60,70), function()
        for _, item in ipairs(state.giftItems) do item.selected = false end
        notify("☐ Cleared", "Selection cleared", 1)
    end)
    clearBtn.Size = UDim2.new(0.23,0,0,24)

    local sendBtn = createButton(btnRow, "📤 Send", Color3.fromRGB(75,125,180), function()
        local recipient = userBox.Text
        if recipient == "" then notify("⚠ Error", "Username kosong", 2) return end
        local qty = tonumber(qtyBox.Text) or 1
        local selected = {}
        for _, item in ipairs(state.giftItems) do
            if item.selected then
                table.insert(selected, { name = item.name, category = item.category, qty = 1 })
            end
        end
        if #selected == 0 then notify("⚠ Error", "Tidak ada item dipilih", 2) return end
        local userId = lookupRecipient(recipient)
        if not userId then notify("⚠ Error", "User tidak ditemukan", 2) return end
        local payload, sent = buildPayloadFromSelection(selected, qty)
        if sent == 0 then notify("⚠ Error", "Tidak ada payload", 2) return end
        local ok, msg = sendMailBatch(userId, payload, "")
        if ok then
            notify("✅ Sent", sent .. " items to " .. recipient, 2.5)
        else
            notify("❌ Failed", msg, 2.5)
        end
    end)
    sendBtn.Size = UDim2.new(0.23,0,0,24)

    -- Auto Gift toggle
    local autoToggle = createToggle(panel, "🔁 Auto Gift", state.giftAuto, function(s)
        state.giftAuto = s
        if s then
            notify("🔄 Auto Gift", "Started", 1.5)
            -- Jalankan loop auto gift
            task.spawn(function()
                while state.giftAuto do
                    local recipient = userBox.Text
                    if recipient == "" then break end
                    local qty = tonumber(qtyBox.Text) or 1
                    local selected = {}
                    for _, item in ipairs(state.giftItems) do
                        if item.selected then
                            table.insert(selected, { name = item.name, category = item.category, qty = 1 })
                        end
                    end
                    if #selected > 0 then
                        local userId = lookupRecipient(recipient)
                        if userId then
                            local payload, sent = buildPayloadFromSelection(selected, qty)
                            if sent > 0 then sendMailBatch(userId, payload, "") end
                        end
                    end
                    task.wait(3)
                end
            end)
        else
            notify("⏹ Auto Gift", "Stopped", 1.5)
        end
    end)

    -- Daftar item (Placeholder - nanti diisi dari inventory)
    local itemFrame = Instance.new("ScrollingFrame")
    itemFrame.BackgroundColor3 = Color3.fromRGB(38,38,38)
    itemFrame.BorderSizePixel = 0
    itemFrame.Size = UDim2.new(1,0,0,200)
    itemFrame.ScrollBarThickness = 4
    itemFrame.Parent = panel

    local itemLayout = Instance.new("UIListLayout")
    itemLayout.Padding = UDim.new(0,2)
    itemLayout.SortOrder = Enum.SortOrder.LayoutOrder
    itemLayout.Parent = itemFrame

    -- Contoh item (nanti diganti dengan data real)
    local function refreshItems()
        for _, child in ipairs(itemFrame:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        state.giftItems = {}
        local allItems = {}
        for _, seed in ipairs(SEED_DATABASE) do table.insert(allItems, {name=seed, category="Seed"}) end
        for _, gear in ipairs(GEAR_DATABASE) do table.insert(allItems, {name=gear, category="Gear"}) end
        for _, pet in ipairs(PET_DATABASE) do table.insert(allItems, {name=pet, category="Pet"}) end
        for _, prop in ipairs(PROPS_DATABASE) do table.insert(allItems, {name=prop, category="Prop"}) end
        for _, item in ipairs(allItems) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1,0,0,22)
            btn.BackgroundColor3 = Color3.fromRGB(60,60,60)
            btn.TextColor3 = Color3.fromRGB(235,235,235)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 11
            btn.Text = item.name .. " [" .. item.category .. "]"
            btn.Parent = itemFrame
            btn:SetAttribute("selected", false)
            btn.MouseButton1Click:Connect(function()
                local sel = not btn:GetAttribute("selected")
                btn:SetAttribute("selected", sel)
                btn.BackgroundColor3 = sel and Color3.fromRGB(90,150,90) or Color3.fromRGB(60,60,60)
                -- Update state
                for _, it in ipairs(state.giftItems) do
                    if it.name == item.name and it.category == item.category then
                        it.selected = sel
                    end
                end
            end)
            table.insert(state.giftItems, { name = item.name, category = item.category, selected = false })
        end
        itemFrame.CanvasSize = UDim2.new(0,0,0, itemLayout.AbsoluteContentSize.Y + 10)
    end
    refreshItems()
end

-- Panel Auto Buy
local function buildBuyPanel(panel)
    -- Toggle Auto Buy
    local autoToggle = createToggle(panel, "🛒 Auto Buy (All)", state.buyAuto, function(s)
        state.buyAuto = s
        if s then
            notify("🛒 Auto Buy", "Started", 1.5)
            task.spawn(function()
                while state.buyAuto do
                    -- Beli semua seed yang dipilih
                    for _, seed in ipairs(state.buySeeds) do
                        if seed.selected then
                            if getStock("Seed", seed.name) > 0 then
                                buyShopItem("Seed", seed.name)
                                task.wait(0.2)
                            end
                        end
                    end
                    -- Beli gear yang dipilih
                    for _, gear in ipairs(state.buyGear) do
                        if gear.selected then
                            if getStock("Gear", gear.name) > 0 then
                                buyShopItem("Gear", gear.name)
                                task.wait(0.2)
                            end
                        end
                    end
                    -- Beli props (fallback ke gear?)
                    for _, prop in ipairs(state.buyProps) do
                        if prop.selected then
                            if getStock("Gear", prop.name) > 0 then
                                buyShopItem("Gear", prop.name)
                                task.wait(0.2)
                            end
                        end
                    end
                    task.wait(5)
                end
            end)
        else
            notify("⏹ Auto Buy", "Stopped", 1.5)
