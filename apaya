-- 6. FUNGSI GET INVENTORY (dari mail exploiter)
-- ============================================================
local function getInventory()
    local inv = {}
    -- Coba ambil dari PlayerStateClient jika ada
    local shared = ReplicatedStorage:FindFirstChild("SharedModules")
    if shared then
        local client = shared:FindFirstChild("ClientModules")
        if client then
            local psc = client:FindFirstChild("PlayerStateClient")
            if psc then
                local ok, replica = pcall(require, psc)
                if ok and replica and replica.GetLocalReplica then
                    local ok2, data = pcall(replica.GetLocalReplica, replica)
                    if ok2 and data and data.Data and data.Data.Inventory then
                        for cat, items in pairs(data.Data.Inventory) do
                            for name, qty in pairs(items) do
                                table.insert(inv, { name = name, category = cat, qty = qty })
                            end
                        end
                        return inv
                    end
                end
            end
        end
    end
    -- Fallback: scan PlayerGui dan Backpack
    local function scan(obj)
        if not obj then return end
        for _, child in ipairs(obj:GetDescendants()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
                local txt = child.Text or ""
                if txt ~= "" then
                    local name = txt:match("^([^%d]+)") or txt
                    local qty = tonumber(txt:match("(%d+)$")) or 1
                    table.insert(inv, { name = normalizeText(name), category = "Unknown", qty = qty })
                end
            end
        end
    end
    scan(LocalPlayer:FindFirstChild("Backpack"))
    scan(LocalPlayer:FindFirstChild("Inventory"))
    scan(PlayerGui)
    return inv
end

