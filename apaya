-- 8. AUTO PLANT & COLLECT (menggunakan fireclickdetector / firetouchinterest)
-- ============================================================
local function findPlots()
    local plots = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and (obj.Name:lower():find("plot") or obj.Name:lower():find("farm")) then
            local det = obj:FindFirstChildWhichIsA("ClickDetector")
            if det then
                table.insert(plots, { part = obj, detector = det })
            end
        end
    end
    return plots
end

local function plantSeed(seedName, position)
    -- Cari plot terdekat dengan posisi
    local plots = findPlots()
    local target = nil
    local minDist = math.huge
    for _, p in ipairs(plots) do
        local dist = (p.part.Position - position).Magnitude
        if dist < minDist then
            minDist = dist
            target = p
        end
    end
    if target and minDist < 20 then
        -- Pindahkan player ke dekat plot
        local char = LocalPlayer.Character
        if char and char.PrimaryPart then
            char.PrimaryPart.CFrame = target.part.CFrame + Vector3.new(0,0,2)
            task.wait(0.3)
            if fireclickdetector then
                fireclickdetector(target.detector)
                return true
            end
        end
    end
    return false
end

local function collectFruit(fruitName)
    local char = LocalPlayer.Character
    if not char or not char.PrimaryPart then return false end
    local collected = false
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name:lower():find(fruitName:lower()) then
            local dist = (obj.Position - char.PrimaryPart.Position).Magnitude
            if dist < 8 then
                if firetouchinterest then
                    firetouchinterest(char.PrimaryPart, obj, 0)
                    firetouchinterest(char.PrimaryPart, obj, 1)
                    collected = true
                end
            end
        end
    end
    return collected
end

