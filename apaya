-- =====================================================
-- SISTEM KEY
-- =====================================================

local VALID_KEYS = {
    ["FREE-2024-001"] = { tier = "free", expiry = os.time() + 86400 * 30 },
    ["VIP-2024-002"] = { tier = "vip", expiry = os.time() + 86400 * 90 },
    ["ADMIN-2024-003"] = { tier = "admin", expiry = os.time() + 86400 * 365 },
    ["TEST-KEY-001"] = { tier = "free", expiry = os.time() + 86400 * 7 },
}

local activeKey = nil
local userTier = "free"  -- Default
local keyExpiry = nil

-- Validasi key
local function validateKey(key)
    key = string.upper(key):gsub("^%s+", ""):gsub("%s+$", "")
    local keyData = VALID_KEYS[key]
    if not keyData then
        return false, "Invalid key!"
    end
    if os.time() > keyData.expiry then
        return false, "Key expired!"
    end
    return true, keyData.tier, keyData.expiry
end

-- Generate key (untuk testing)
local function generateKey(tier)
    tier = tier or "free"
    local prefixes = { free = "FREE", vip = "VIP", admin = "ADMIN" }
    local prefix = prefixes[tier] or "FREE"
    local random = math.random(1000, 9999)
    local key = string.format("%s-%d-%04d", prefix, os.time() % 10000, random)
    VALID_KEYS[key] = { tier = tier, expiry = os.time() + 86400 * 30 }
    return key
end

