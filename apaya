    syncBtn.LayoutOrder = 1

    -- Tombol Rejoin
    local rejoinBtn = createButton("↻ Rejoin Server", Color3.fromRGB(50, 40, 60), function()
        showNotification("↻ Rejoining", "Connecting to server...", 2,
            Color3.fromRGB(40, 35, 45),
            Color3.fromRGB(230, 200, 240))
        delay(1, function()
            local success, err = pcall(function()
                TeleportService:Teleport(game.PlaceId, LocalPlayer)
            end)
            if not success then
                showNotification("✗ Rejoin Failed", tostring(err), 3,
                    Color3.fromRGB(50, 30, 35),
                    Color3.fromRGB(255, 180, 180))
            end
        end)
    end)
    rejoinBtn.Parent = scrollFrame
    rejoinBtn.LayoutOrder = 2

    -- Tombol Reset
    local resetBtn = createButton("🔄 Reset Character", Color3.fromRGB(70, 40, 40), function()
        if LocalPlayer.Character then
            LocalPlayer.Character:BreakJoints()
            showNotification("🔄 Reset", "Character reset!", 1.5,
                Color3.fromRGB(50, 40, 30),
                Color3.fromRGB(255, 200, 150))
        end
    end)
    resetBtn.Parent = scrollFrame
    resetBtn.LayoutOrder = 3

    -- Tombol Test Deteksi Item
    local testBtn = createButton("🔍 Test Item Detection", Color3.fromRGB(40, 40, 60), function()
        local testItems = {"Acorn", "Bee", "Common Sprinkler", "Dragon Fruit", "Bunny", "Trowel"}
        local results = {}
        for _, item in ipairs(testItems) do
            local cat, name = findItemInDatabase(item)
            if cat then
                table.insert(results, item .. " → " .. cat .. ": " .. name)
            else
                table.insert(results, item .. " → NOT FOUND")
            end
        end
        showNotification("🔍 Detection Test", table.concat(results, "\n"), 5,
            Color3.fromRGB(40, 50, 60),
            Color3.fromRGB(200, 220, 255))
    end)
    testBtn.Parent = scrollFrame
    testBtn.LayoutOrder = 4

    -- Update canvas
    local function updateCanvasSize()
        local contentHeight = layout.AbsoluteContentSize.Y
        local newHeight = GUI_PADDING * 2 + contentHeight + GUI_SPACING
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, newHeight)
        local visibleHeight = math.min(newHeight + GUI_TITLE_HEIGHT + 20, 400)
        mainFrame.Size = UDim2.new(0, GUI_WIDTH, 0, visibleHeight)
    end

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvasSize)
    updateCanvasSize()

    -- Drag
    local isDragging = false
    local dragStartPos = nil
    local frameStartPos = nil

    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            dragStartPos = input.Position
            frameStartPos = mainFrame.Position
        end
    end)

    topBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
            dragStartPos = nil
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.Position then
            local delta = input.Position - dragStartPos
            local newX = frameStartPos.X.Offset + delta.X
            local newY = frameStartPos.Y.Offset + delta.Y

            local viewportSize = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(800, 600)
            local maxX = math.max(0, viewportSize.X - mainFrame.AbsoluteSize.X)
            local maxY = math.max(0, viewportSize.Y - mainFrame.AbsoluteSize.Y)

            newX = math.clamp(newX, 0, maxX)
            newY = math.clamp(newY, 0, maxY)

            mainFrame.Position = UDim2.new(0, newX, 0, newY)
        end
    end)

    -- Minimize
    local isMinimized = false
    local originalSize = mainFrame.Size

    minimizeBtn.MouseButton1Click:Connect(function()
        isMinimized = not isMinimized

        if isMinimized then
            TweenService:Create(mainFrame, TweenInfo.new(0.22), {
                Size = UDim2.new(0, GUI_WIDTH, 0, GUI_TITLE_HEIGHT)
            }):Play()
            contentArea.Visible = false
            minimizeBtn.Text = "□"
        else
            contentArea.Visible = true
            TweenService:Create(mainFrame, TweenInfo.new(0.22, Enum.EasingStyle.Back), {
                Size = originalSize
            }):Play()
            minimizeBtn.Text = "—"
        end
    end)

    -- Animate in
    mainFrame.Position = UDim2.new(1, 200, 0, 20)
    mainFrame.BackgroundTransparency = 1

    TweenService:Create(mainFrame, TweenInfo.new(0.36, Enum.EasingStyle.Quad), {
        BackgroundTransparency = 0
    }):Play()

    TweenService:Create(mainFrame, TweenInfo.new(0.36, Enum.EasingStyle.Back), {
        Position = UDim2.new(1, -GUI_WIDTH - 40, 0, 20)
    }):Play()

    container.AncestryChanged:Connect(function()
        if not container:IsDescendantOf(game) then
            clearConnections()
            pcall(function()
                PlayerGui:SetAttribute("HubInitialized", nil)
            end)
        end
    end)

    return container
end

