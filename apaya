local function createToggle(text, defaultState, callback)
    local data = { Enabled = defaultState or false }
    local container = createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(35, 30, 38),
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, CONFIG.ToggleHeight + 12),
    })
    local button = createInstance("ImageButton", {
        BackgroundColor3 = Color3.fromRGB(40, 35, 45),
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 0),
        Size = UDim2.new(1, 0, 1, 0),
        AutoButtonColor = false,
        Parent = container
    })
    createInstance("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = text,
        TextColor3 = Color3.fromRGB(220, 200, 210),
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, CONFIG.Padding, 0, 0),
        Size = UDim2.new(0.65, -CONFIG.Padding, 1, 0),
        Parent = container
    })
    local toggleFrame = createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(50, 45, 55),
        BorderSizePixel = 0,
        Position = UDim2.new(1, -50 - CONFIG.Padding, 0.5, -10),
        Size = UDim2.new(0, 36, 0, 20),
        Parent = container
    })
    local toggleInner = createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(80, 70, 90),
        BorderSizePixel = 0,
        Position = UDim2.new(0, 2, 0, 2),
        Size = UDim2.new(0, 16, 0, 16),
        Parent = toggleFrame
    })
    local statusLabel = createInstance("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = "OFF",
        TextColor3 = Color3.fromRGB(160, 140, 150),
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Right,
        Position = UDim2.new(1, -58 - CONFIG.Padding, 0.5, -10),
        Size = UDim2.new(0, 35, 0, 20),
        Parent = container
    })
    data.Container = container
    data.Frame = toggleFrame
    data.Inner = toggleInner
    data.Status = statusLabel

    local function update(state)
        data.Enabled = state
        TweenService:Create(toggleInner, TweenInfo.new(CONFIG.AnimSpeed, Enum.EasingStyle.Quad), {
            Position = state and UDim2.new(1, -18, 0, 2) or UDim2.new(0, 2, 0, 2),
            BackgroundColor3 = state and Color3.fromRGB(100, 200, 100) or Color3.fromRGB(80, 70, 90)
        }):Play()
        TweenService:Create(toggleFrame, TweenInfo.new(CONFIG.AnimSpeed), {
            BackgroundColor3 = state and Color3.fromRGB(60, 150, 60) or Color3.fromRGB(50, 45, 55)
        }):Play()
        TweenService:Create(statusLabel, TweenInfo.new(CONFIG.AnimSpeed), {
            Text = state and "ON" or "OFF",
            TextColor3 = state and Color3.fromRGB(120, 220, 120) or Color3.fromRGB(160, 140, 150)
        }):Play()
        if callback then callback(state) end
    end
    button.MouseButton1Click:Connect(function() update(not data.Enabled) end)
    update(defaultState)
    return data
end

local function createButton(text, color, onClick)
    local btn = createInstance("TextButton", {
        BackgroundColor3 = color or Color3.fromRGB(50, 40, 60),
        BorderSizePixel = 0,
        Font = Enum.Font.GothamBold,
        Text = text,
        TextColor3 = Color3.fromRGB(240, 220, 245),
        TextSize = 14,
        AutoButtonColor = false,
        Size = UDim2.new(1, 0, 0, CONFIG.ButtonHeight),
    })
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.08), {
            BackgroundColor3 = btn.BackgroundColor3:Lerp(Color3.new(0.15, 0.05, 0.2), 0.1)
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.08), {
            BackgroundColor3 = btn.BackgroundColor3:Lerp(Color3.new(0.2, 0.15, 0.25), 0.1)
        }):Play()
    end)
    if onClick then btn.MouseButton1Click:Connect(onClick) end
    return btn
end

