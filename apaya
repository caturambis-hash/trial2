    end)
    speedToggle.Container.Parent = scrollFrame
    speedToggle.Container.LayoutOrder = 4
    
    -- Toggle 5: Multi Tab
    local multiToggle = createToggle("📑 Multi Tab", features.multiTab, function(state)
        toggleMultiTab(state)
    end)
    multiToggle.Container.Parent = scrollFrame
    multiToggle.Container.LayoutOrder = 5
    
    -- Toggle 6: ESP
    local espToggle = createToggle("👁 ESP", features.esp, function(state)
        toggleESP(state)
    end)
    espToggle.Container.Parent = scrollFrame
    espToggle.Container.LayoutOrder = 6
    
    -- Button: Rejoin
    local rejoinBtn = createButton("↻ Rejoin Server", Color3.fromRGB(50, 40, 60), function()
        showNotification("↻ Rejoining", "Menghubungkan ulang...", 2,
            Color3.fromRGB(40, 35, 45), Color3.fromRGB(230, 200, 240))
        
        delay(0.8, function()
            local success, err = pcall(function()
                TeleportService:Teleport(game.PlaceId, player)
            end)
            if not success then
                showNotification("✗ Rejoin Failed", tostring(err), 2.5,
                    Color3.fromRGB(60, 30, 35), Color3.fromRGB(255, 180, 180))
            end
        end)
    end)
    rejoinBtn.Parent = scrollFrame
    rejoinBtn.LayoutOrder = 7
    
    -- Admin button (hanya untuk admin)
    if userTier == "admin" then
        local adminBtn = createButton("⚙ Admin Panel", Color3.fromRGB(80, 40, 60), function()
            showNotification("⚙ Admin Panel", "Fitur admin aktif!", 2,
                Color3.fromRGB(40, 30, 50), Color3.fromRGB(255, 200, 150))
        end)
        adminBtn.Parent = scrollFrame
        adminBtn.LayoutOrder = 8
    end
    
    -- Update canvas
    local function updateSize()
        local contentHeight = layout.AbsoluteContentSize.Y
        local newHeight = CONFIG.Padding * 2 + contentHeight + CONFIG.Spacing + 10
        scrollFrame.CanvasSize = UDim2.new(0, 0, 0, newHeight)
        local visibleHeight = math.min(newHeight + CONFIG.TitleHeight + 10, 400)
        mainFrame.Size = UDim2.new(0, CONFIG.Width, 0, visibleHeight)
    end
    
    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateSize)
    updateSize()
    
    -- =====================================================
    -- DRAG
    -- =====================================================
    
    local isDragging = false
    local dragStart = nil
    local frameStart = nil
    
    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            dragStart = input.Position
            frameStart = mainFrame.Position
        end
    end)
    
    topBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or
           input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.Position then
            local delta = input.Position - dragStart
            local newX = frameStart.X.Offset + delta.X
            local newY = frameStart.Y.Offset + delta.Y
            local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(800, 600)
            local maxX = math.max(0, viewport.X - mainFrame.AbsoluteSize.X)
            local maxY = math.max(0, viewport.Y - mainFrame.AbsoluteSize.Y)
            mainFrame.Position = UDim2.new(0, math.clamp(newX, 0, maxX), 0, math.clamp(newY, 0, maxY))
        end
    end)
    
    -- =====================================================
    -- MINIMIZE
    -- =====================================================
    
    local isMinimized = false
    local originalSize = mainFrame.Size
    
    minimizeBtn.MouseButton1Click:Connect(function()
        isMinimized = not isMinimized
        if isMinimized then
            TweenService:Create(mainFrame, TweenInfo.new(CONFIG.AnimationSpeed), {
                Size = UDim2.new(0, CONFIG.Width, 0, CONFIG.TitleHeight)
            }):Play()
            contentArea.Visible = false
            minimizeBtn.Text = "□"
        else
            contentArea.Visible = true
            TweenService:Create(mainFrame, TweenInfo.new(CONFIG.AnimationSpeed, Enum.EasingStyle.Back), {
                Size = originalSize
            }):Play()
            minimizeBtn.Text = "—"
        end
    end)
    
    -- =====================================================
    -- ANIMASI MASUK - CEPAT
    
    mainFrame.BackgroundTransparency = 1
    TweenService:Create(mainFrame, TweenInfo.new(CONFIG.AnimationSpeed), {
        BackgroundTransparency = 0
    }):Play()
    
    TweenService:Create(mainFrame, TweenInfo.new(CONFIG.AnimationSpeed + 0.1, Enum.EasingStyle.Back), {
        Position = UDim2.new(1, -CONFIG.Width - 40, 0, 20)
    }):Play()
    
    -- Cleanup
    container.AncestryChanged:Connect(function()
        if not container:IsDescendantOf(game) then
            clearConnections()
            pcall(function()
                playerGui:SetAttribute("HubInitialized", nil)
            end)
        end
    end)
    
    return container
end

-- =====================================================
-- INISIALISASI
-- =====================================================

local function initialize()
    if playerGui:GetAttribute("HubInitialized") then
        return
    end
    playerGui:SetAttribute("HubInitialized", true)
    
    showKeyInput()
end

