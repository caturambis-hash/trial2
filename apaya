        Parent = frame,
    })

    frame.Position = UDim2.new(1, 400, 0, 20)
    TweenService:Create(frame, TweenInfo.new(0.28, Enum.EasingStyle.Quad), {
        Position = UDim2.new(1, -GUI_WIDTH - 40, 0, 20)
