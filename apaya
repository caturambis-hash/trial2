local function normalizeText(t) return tostring(t or ""):lower():gsub("%s+"," "):gsub("^%s*(.-)%s*$","%1") end

-- ============================================================
-- REMOTE & NETWORKING
-- ============================================================
local RemoteEvent = nil
local function getRemote()
    if not RemoteEvent then
        local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
        if not r then
            local p = ReplicatedStorage:FindFirstChild("Packet")
            if p then r = p:FindFirstChild("RemoteEvent") end
        end
        RemoteEvent = r
    end
    return RemoteEvent
end

local function fireServer(action, data)
    local remote = getRemote()
    if remote then pcall(function() remote:FireServer(action, data) end) end
end

-- ============================================================
-- AUTO BUY (dari kode sebelumnya)
-- ============================================================
local function buyShopItem(shopKey, itemName)
    local remote = getRemote()
    if not remote then return false end
    local prefix = shopKey == "Seed" and "j" or (shopKey == "Gear" and "n" or "")
    if prefix == "" then return false end
    local payload = buffer.fromstring(prefix .. "\x00" .. string.char(#itemName) .. itemName)
    pcall(function() remote:FireServer(payload) end)
    return true
end

local function getStock(shopKey, itemName)
    local folder = ReplicatedStorage:FindFirstChild("StockValues")
    if not folder then return 0 end
    local shop = folder:FindFirstChild(shopKey == "Seed" and "SeedShop" or "GearShop")
    if not shop then return 0 end
    local items = shop:FindFirstChild("Items")
    if not items then return 0 end
    local val = items:FindFirstChild(itemName)
    if val and (val:IsA("IntValue") or val:IsA("NumberValue")) then return val.Value end
    return 0
end

-- ============================================================
-- AUTO GIFT MAIL (dari kode sebelumnya)
-- ============================================================
local function lookupRecipient(username)
    local remote = getRemote()
    if remote then
        local ok, res = pcall(function() return remote:InvokeServer("LookupPlayer", username) end)
        if ok and type(res) == "number" and res > 0 then return res end
    end
    local ok, id = pcall(Players.GetUserIdFromNameAsync, Players, username)
    if ok and type(id) == "number" and id > 0 then return id end
    return nil
end

local function sendMailBatch(userId, payload, note)
    local remote = getRemote()
    if not remote then return false, "Remote not found" end
    local ok, res, msg = pcall(function()
        return remote:InvokeServer("SendBatch", userId, payload, tostring(note or ""))
    end)
    if not ok then return false, tostring(res) end
    if res == true then return true, tostring(msg or "Sent") end
    return false, tostring(msg or "Failed")
end

