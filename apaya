    end)

    -- ============================================================
    -- ISI TAB BUY
    -- ============================================================
    addToggle(buyPanel, "🌱 Auto Buy Seeds", false, function(s)
        if s then
            notify("🌱 Auto Buy Seeds", "Started", 1.5)
            toggleBuySeed(s)
        else
            notify("⏹ Auto Buy Seeds", "Stopped", 1.5)
            toggleBuySeed(s)
        end
    end)

    addToggle(buyPanel, "🔧 Auto Buy Gear", false, function(s)
        if s then
            notify("🔧 Auto Buy Gear", "Started", 1.5)
            toggleBuyGear(s)
        else
            notify("⏹ Auto Buy Gear", "Stopped", 1.5)
            toggleBuyGear(s)
        end
    end)

    -- ============================================================
    -- ISI TAB FARM
    -- ============================================================
    addToggle(farmPanel, "🌾 Auto Farm", false, function(s) toggleFarm(s) end)
    addToggle(farmPanel, "🖱 Auto Click", false, function(s) toggleClick(s) end)
    addToggle(farmPanel, "📦 Auto Collect", false, function(s) toggleCollect(s) end)
    addToggle(farmPanel, "🌱 Auto Plant", false, function(s) togglePlant(s) end)

    -- ============================================================
    -- ISI TAB UTIL
    -- ============================================================
    addToggle(utilPanel, "⚡ Speed Boost", false, function(s) toggleSpeed(s) end)
    addToggle(utilPanel, "✈️ Fly Mode", false, function(s) toggleFly(s) end)
    addToggle(utilPanel, "🚪 No Clip", false, function(s) toggleNoClip(s) end)
    addToggle(utilPanel, "👁 ESP", false, function(s) toggleESP(s) end)
    addToggle(utilPanel, "🔄 Rollback", false, function(s) toggleRollback(s) end)

    -- Tombol
    local rejoinBtn = addButton(utilPanel, "↻ Rejoin Server", Color3.fromRGB(50,70,100), function()
        notify("↻ Rejoining", "Connecting...", 2)
        delay(0.8, function() pcall(function() TeleportService:Teleport(game.PlaceId, LocalPlayer) end) end)
    end)
    local resetBtn = addButton(utilPanel, "🔄 Reset Character", Color3.fromRGB(100,50,50), function()
        if LocalPlayer.Character then LocalPlayer.Character:BreakJoints() end
        notify("🔄 Reset", "Character reset", 1.5)
    end)

    -- ============================================================
    -- DRAG & MINIMIZE
    -- ============================================================
    local dragging = false
    local dragStart, frameStart
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            frameStart = mainFrame.Position
        end
    end)
    titleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.Position then
            local delta = input.Position - dragStart
            local newX = frameStart.X.Offset + delta.X
            local newY = frameStart.Y.Offset + delta.Y
            local vp = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(800,600)
            local maxX = math.max(0, vp.X - mainFrame.AbsoluteSize.X)
            local maxY = math.max(0, vp.Y - mainFrame.AbsoluteSize.Y)
            mainFrame.Position = UDim2.new(0, math.clamp(newX,0,maxX), 0, math.clamp(newY,0,maxY))
        end
    end)

    local minimized = false
    local origSize = mainFrame.Size
    minBtn.Activated:Connect(function()
        minimized = not minimized
        if minimized then
            TweenService:Create(mainFrame, TweenInfo.new(0.15), {
                Size = UDim2.new(0, mainFrame.Size.X.Offset, 0, 34)
            }):Play()
            content.Visible = false
            sidebar.Visible = false
            minBtn.Text = "□"
        else
            content.Visible = true
            sidebar.Visible = true
            TweenService:Create(mainFrame, TweenInfo.new(0.15, Enum.EasingStyle.Back), {
                Size = origSize
            }):Play()
            minBtn.Text = "—"
        end
    end)

    -- Animate in
    mainFrame.BackgroundTransparency = 1
    TweenService:Create(mainFrame, TweenInfo.new(0.2), { BackgroundTransparency = 0 }):Play()
    mainFrame.Position = UDim2.new(0.5, -220, 0.08, 50)
    TweenService:Create(mainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
        Position = UDim2.new(0.5, -220, 0.08, 0)
    }):Play()

    screen.AncestryChanged:Connect(function()
        if not screen:IsDescendantOf(game) then
            for _, c in ipairs(connections) do if c and c.Connected then c:Disconnect() end end
            connections = {}
        end
    end)

    return screen
end

