    delay(duration, function()
        if frame and frame.Parent then
            TweenService:Create(frame, TweenInfo.new(0.26, Enum.EasingStyle.Quad), {
                Position = UDim2.new(1, 400, 0, 20)
            }):Play()
            delay(0.3, function()
                if container and container.Parent then
                    container:Destroy()
                end
            end)
        end
    end)

    return container
end

