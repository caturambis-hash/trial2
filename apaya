-- ============================================================
local function init()
    if PlayerGui:GetAttribute("GiftHubInitialized") then return end
    PlayerGui:SetAttribute("GiftHubInitialized", true)
    notify("Loading", "Auto Gift Mail...")
    delay(0.5, function()
        pcall(buildUI)
    end)
end

spawn(init)
print("📨 Auto Gift Mail script loaded!")
