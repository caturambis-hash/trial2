    if PlayerGui:GetAttribute("HubInitialized") then return end
    PlayerGui:SetAttribute("HubInitialized", true)
    notify("🌱 Hub Loaded", "Welcome " .. PlayerName, 2)
    delay(0.5, function() pcall(buildUI) end)
end

