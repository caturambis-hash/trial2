local function getItemDatabase()
    local db = { Seeds = {}, Gear = {}, Pets = {}, Props = {} }
    -- Coba ambil dari StockValues
    local stock = ReplicatedStorage:FindFirstChild("StockValues")
    if stock then
        local seedShop = stock:FindFirstChild("SeedShop")
        if seedShop then
            local items = seedShop:FindFirstChild("Items")
            if items then
                for _, child in ipairs(items:GetChildren()) do
                    if child:IsA("IntValue") or child:IsA("NumberValue") then
                        table.insert(db.Seeds, child.Name)
                    end
                end
            end
        end
        local gearShop = stock:FindFirstChild("GearShop")
        if gearShop then
            local items = gearShop:FindFirstChild("Items")
            if items then
                for _, child in ipairs(items:GetChildren()) do
                    if child:IsA("IntValue") or child:IsA("NumberValue") then
                        table.insert(db.Gear, child.Name)
                    end
                end
            end
        end
    end
    -- Fallback jika tidak ditemukan
    if #db.Seeds == 0 then
        db.Seeds = {"Acorn","Apple","Bamboo","Banana","Blueberry","Briar Rose","Cactus",
            "Carrot","Cherry","Coconut","Corn","Dragon Fruit","Dragon's Breath",
            "Grape","Green Bean","Hypno Bloom","Mango","Moon Bloom","Mushroom",
            "Pineapple","Poison Apple","Pomegranate","Pumpkin","Strawberry",
            "Sunflower","Tomato","Tulip","Venom Spitter","Venus Fly Trap","Watermelon"}
    end
    if #db.Gear == 0 then
        db.Gear = {"Common Watering Can","Common Sprinkler","Uncommon Sprinkler","Rare Sprinkler",
            "Legendary Sprinkler","Super Watering Can","Super Sprinkler",
            "Jump Mushroom","Speed Mushroom","Shrink Mushroom","Supersize Mushroom",
            "Invisibility Mushroom","Trowel","Sign","Lantern","Megaphone",
            "Gnome","Flashbang","Basic Pot","Teleporter","Wheelbarrow",
            "Strawberry Sniper","Player Magnet"}
    end
    if #db.Pets == 0 then
        db.Pets = {"Bee","Bear","Bunny","Cat","Cow","Deer","Dog","Dragon","Eagle",
            "Fox","Frog","Giraffe","Horse","Lion","Monkey","Owl","Panda",
            "Penguin","Pig","Rabbit","Raccoon","Sheep","Snake","Squirrel",
            "Tiger","Turtle","Unicorn","Wolf","Zebra"}
    end
    if #db.Props == 0 then
        db.Props = {"Sign","Lantern","Gnome","Basic Pot","Teleporter","Wheelbarrow"}
    end
    return db
end

