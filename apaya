-- ============================================================
-- FUNGSI UTILITY
-- ============================================================
local function normalizeText(text)
    local t = tostring(text or ""):lower()
    t = t:gsub("%s+", " "):gsub("^%s*(.-)%s*$", "%1")
    return t
end

local function findItemInDatabase(input)
    local normalized = normalizeText(input)
    if normalized == "" then return nil, nil end
    for _, item in ipairs(SEED_DATABASE) do
        local itemNorm = normalizeText(item)
        if normalized == itemNorm then return "Seeds", item end
        local aliases = SEED_ALIASES[item]
        if aliases then
            for _, alias in ipairs(aliases) do
                if normalized == normalizeText(alias) or normalized:find(normalizeText(alias), 1, true) then
                    return "Seeds", item
                end
            end
        end
    end
    for _, item in ipairs(PET_DATABASE) do
        local itemNorm = normalizeText(item)
        if normalized == itemNorm then return "Pets", item end
        local aliases = PET_ALIASES[item]
        if aliases then
            for _, alias in ipairs(aliases) do
                if normalized == normalizeText(alias) or normalized:find(normalizeText(alias), 1, true) then
                    return "Pets", item
                end
            end
        end
    end
    for _, item in ipairs(GEAR_DATABASE) do
        local itemNorm = normalizeText(item)
        if normalized == itemNorm then return "Gear", item end
        local aliases = GEAR_ALIASES[item]
        if aliases then
            for _, alias in ipairs(aliases) do
                if normalized == normalizeText(alias) or normalized:find(normalizeText(alias), 1, true) then
                    return "Gear", item
                end
            end
        end
    end
    return nil, nil
end

local function categorizeItem(input)
    local cat, _ = findItemInDatabase(input)
    return cat or "Other"
end

-- ============================================================
-- REMOTE EVENT
-- ============================================================
local RemoteEvent = nil
local function getRemoteEvent()
    if not RemoteEvent then
        local possible = {
            ReplicatedStorage:FindFirstChild("RemoteEvent"),
            ReplicatedStorage:FindFirstChild("SharedModules") and ReplicatedStorage.SharedModules:FindFirstChild("Packet") and ReplicatedStorage.SharedModules.Packet:FindFirstChild("RemoteEvent"),
            ReplicatedStorage:FindFirstChild("Packet") and ReplicatedStorage.Packet:FindFirstChild("RemoteEvent"),
        }
        for _, p in ipairs(possible) do
            if p then RemoteEvent = p break end
        end
    end
    return RemoteEvent
end

local function fireServer(action, data)
    local remote = getRemoteEvent()
    if remote then
        pcall(function() remote:FireServer(action, data) end)
    end
end

