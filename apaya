local SharedModules = ReplicatedStorage:FindFirstChild("SharedModules")
local ClientModules = ReplicatedStorage:FindFirstChild("ClientModules")
local Networking, PlayerStateClient, MailboxItemCatalog

local function safeRequire(m)
    if not m then return nil end
    local ok, r = pcall(require, m)
    return ok and r or nil
end

local function loadNetworkingModules()
    if SharedModules then Networking = safeRequire(SharedModules:FindFirstChild("Networking")) end
    if ClientModules then PlayerStateClient = safeRequire(ClientModules:FindFirstChild("PlayerStateClient")) end
    local catModule = (function()
        local ps = LocalPlayer:FindFirstChild("PlayerScripts")
        local ctrl = ps and ps:FindFirstChild("Controllers")
        local mc = ctrl and ctrl:FindFirstChild("MailboxController")
        local m = mc and mc:FindFirstChild("MailboxItemCatalog")
        if m and m:IsA("ModuleScript") then return m end
        return ReplicatedStorage:FindFirstChild("MailboxItemCatalog", true)
    end)()
    if catModule then MailboxItemCatalog = safeRequire(catModule) end
end
loadNetworkingModules()

local function normalizeUsername(v)
    return tostring(v or ""):gsub("^%s*@?(.-)%s*$", "%1")
end

local function callRemoteMethod(target, ...)
    if not target then return nil end
    local args = {...}
    if target.Fire then
        local ok, res = pcall(target.Fire, target, unpack(args))
        if ok then return res end
    end
    if target.FireServer then
        local ok, res = pcall(target.FireServer, target, unpack(args))
        if ok then return res end
    end
    if target.InvokeServer then
        local ok, res = pcall(target.InvokeServer, target, unpack(args))
        if ok then return res end
    end
    if target.Invoke then
        local ok, res = pcall(target.Invoke, target, unpack(args))
        if ok then return res end
    end
    return nil
end

local function getLocalInventory()
    if not PlayerStateClient then return nil end
    local ok, rep = pcall(PlayerStateClient.GetLocalReplica, PlayerStateClient)
    if not ok or not rep or not rep.Data or not rep.Data.Inventory then return nil end
    return rep.Data.Inventory
end

local function collectReplicaInventoryEntries()
    local inv = getLocalInventory()
    if not inv then return {} end
    local entries = {}
    for cat, data in pairs(inv) do
        if cat == "Pets" then
            for key, val in pairs(data) do
                if val and val.Id and not val.Equipped then
                    table.insert(entries, {
                        DisplayName = val.Name or key,
                        Owned = 1,
                        ItemKey = key,
                        InventoryCategory = "Pets",
                        Category = "Pets"
                    })
                end
            end
        elseif cat == "Seeds" or cat == "Gear" then
            for key, qty in pairs(data) do
                if qty > 0 then
                    table.insert(entries, {
                        DisplayName = key,
                        Owned = qty,
                        ItemKey = key,
                        InventoryCategory = cat,
                        Category = cat
                    })
                end
            end
        end
    end
    return entries
end

local function lookupRecipient(username)
    username = normalizeUsername(username)
    if username == "" then return nil end
    if Networking and Networking.Mailbox and Networking.Mailbox.LookupPlayer then
        local ok, res = pcall(function()
            return callRemoteMethod(Networking.Mailbox.LookupPlayer, username)
        end)
        if ok and type(res) == "number" and res > 0 then return res end
    end
    local ok, id = pcall(Players.GetUserIdFromNameAsync, Players, username)
    if ok and type(id) == "number" and id > 0 then return id end
    return nil
end

local function sendBatch(userId, payload, note)
    if not Networking or not Networking.Mailbox or not Networking.Mailbox.SendBatch then
        return false, "SendBatch not found"
    end
    local ok, res, msg = pcall(function()
        return callRemoteMethod(Networking.Mailbox.SendBatch, userId, payload, tostring(note or ""))
    end)
    if not ok then return false, tostring(res) end
    if res == true then return true, tostring(msg or "Sent") end
    return false, tostring(msg or "Failed")
end

