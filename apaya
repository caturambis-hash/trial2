-- Connections list
local connections = {}

local function addConnection(conn)
    if conn then
        table.insert(connections, conn)
    end
end

local function clearConnections()
    for _, conn in ipairs(connections) do
        if conn and conn.Connected then
            pcall(function() conn:Disconnect() end)
        end
    end
    connections = {}
end

-- Create instance helper
local function createInstance(className, properties)
    local inst = Instance.new(className)
    if properties then
        for prop, value in pairs(properties) do
            inst[prop] = value
        end
    end
    return inst
end

-- Show notification (toast)
local function showNotification(text, subText, duration, bgColor, textColor)
    duration = duration or 3
    bgColor = bgColor or Color3.fromRGB(60, 40, 50)
    textColor = textColor or Color3.fromRGB(230, 200, 240)

    local container = createInstance("ScreenGui", {
        Name = "NotificationContainer",
        IgnoreGuiInset = true,
        Parent = PlayerGui,
    })

    local frame = createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(30, 30, 35),
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 20),
        Size = UDim2.new(0, GUI_WIDTH, 0, 84),
        Parent = container,
    })

    -- Shadow
    createInstance("Frame", {
        BackgroundColor3 = Color3.fromRGB(0, 0, 0),
        BackgroundTransparency = 0.4,
        BorderSizePixel = 0,
        Position = UDim2.new(0, -2, 0, 2),
        Size = UDim2.new(1, 4, 1, 4),
        Parent = frame,
    })

    -- Title
    createInstance("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.GothamBold,
        Text = text,
        TextColor3 = textColor,
        TextSize = 18,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, GUI_PADDING, 0, 10),
        Size = UDim2.new(1, -GUI_PADDING * 2, 0, 24),
        Parent = frame,
    })

    -- Sub text
    createInstance("TextLabel", {
        BackgroundTransparency = 1,
        Font = Enum.Font.Gotham,
        Text = subText or "",
        TextColor3 = Color3.fromRGB(180, 160, 170),
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = UDim2.new(0, GUI_PADDING, 0, 40),
        Size = UDim2.new(1, -GUI_PADDING * 2, 0, 30),
        Parent = frame,
    })

    -- Animate in
    frame.Position = UDim2.new(1, 400, 0, 20)
    TweenService:Create(frame, TweenInfo.new(0.28, Enum.EasingStyle.Quad), {
        Position = UDim2.new(1, -GUI_WIDTH - 40, 0, 20)
    }):Play()

    delay(duration, function()
        if frame and frame.Parent then
            TweenService:Create(frame, TweenInfo.new(0.26, Enum.EasingStyle.Quad), {
                Position = UDim2.new(1, 400, 0, 20)
            }):Play()
            delay(0.3, function()
                if container and container.Parent then
                    container:Destroy()
                end
            end)
        end
    end)

    return container
end

