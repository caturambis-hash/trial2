-- ============================================================
-- FUNGSI UTILITY
-- ============================================================
local function normalizeText(t) return tostring(t or ""):lower():gsub("%s+"," "):gsub("^%s*(.-)%s*$","%1") end

local function findItem(input)
    local n = normalizeText(input)
    for _, item in ipairs(SEED_DATABASE) do
        if normalizeText(item) == n then return "Seeds", item end
    end
    for _, item in ipairs(GEAR_DATABASE) do
        if normalizeText(item) == n then return "Gear", item end
    end
    return nil, nil
end

-- ============================================================
-- REMOTE & AUTO BUY
-- ============================================================
local function getRemote()
    local r = ReplicatedStorage:FindFirstChild("RemoteEvent")
    if not r then
        local p = ReplicatedStorage:FindFirstChild("Packet")
        if p then r = p:FindFirstChild("RemoteEvent") end
    end
    return r
end

local function buyShopItem(shopKey, itemName)
    local remote = getRemote()
    if not remote then return false end
    local prefix = shopKey == "Seed" and "j" or "n"
    local payload = buffer.fromstring(prefix .. "\x00" .. string.char(#itemName) .. itemName)
    pcall(function() remote:FireServer(payload) end)
    return true
end

local function getStock(shopKey, itemName)
    local folder = ReplicatedStorage:FindFirstChild("StockValues")
    if not folder then return 0 end
    local shop = folder:FindFirstChild(shopKey == "Seed" and "SeedShop" or "GearShop")
    if not shop then return 0 end
    local items = shop:FindFirstChild("Items")
    if not items then return 0 end
    local val = items:FindFirstChild(itemName)
    if val and (val:IsA("IntValue") or val:IsA("NumberValue")) then
        return val.Value
    end
    return 0
end

